<%- include('../partials/header') %>

<div class="container my-4 pb-5">
  <div class="row mb-4 align-items-center">
    <div class="col-12 text-center">
      <h2 class="fw-bold mb-2 arabic-title-highlight" style="font-family: var(--font-arabic); font-size: 2.2rem; color: var(--accent-color);">اسأل عن الحديث AI</h2>
      <h4 class="fw-bold text-secondary">Tanya Hadits AI</h4>
      <p class="text-muted small">Ajukan pertanyaan keagamaan Anda, AI akan merangkum jawaban berdasarkan referensi hadits sahih yang ada di database.</p>
    </div>
  </div>

  <!-- Form Section -->
  <div class="row justify-content-center mb-4" id="formRow">
    <div class="col-md-9 col-lg-8">
      <div class="card shadow-sm border-0 p-4 rounded-4" style="background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border) !important;">
        <form id="tanyaForm">
          <div class="mb-3">
            <label for="pertanyaan" class="form-label fw-bold text-success"><i class="fa-solid fa-circle-question me-1"></i> Pertanyaan Anda:</label>
            <textarea name="pertanyaan" id="pertanyaan" class="form-control border-success-subtle rounded-3" rows="3" placeholder="Contoh: Bolehkah berkurban dengan sapi betina?" required style="resize: none; font-size: 1.05rem;"></textarea>
          </div>
          <div class="text-end">
            <button type="submit" id="submitBtn" class="btn btn-success px-4 py-2 fw-bold shadow-sm rounded-pill" style="background: linear-gradient(135deg, var(--accent-color) 0%, var(--accent-color-hover) 100%); border: none;">
              <i class="fa-solid fa-paper-plane me-1"></i> Tanya BaknusAI
            </button>
          </div>
        </form>

        <!-- Loading Spinner (Hidden by default) -->
        <div id="loadingState" class="text-center py-5 d-none">
          <div class="spinner-border text-success mb-3" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
          <h5 class="text-secondary fw-bold">Sedang Merumuskan Jawaban...</h5>
          <p class="text-muted small mb-0">BaknusAI sedang menyaring referensi hadits dan merangkum penjelasan hukumnya untuk Anda.</p>
          <div class="mt-2 text-muted-50 small text-center" id="pollingStatus">Menghubungkan ke AI server...</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Error Message Container (Hidden by default) -->
  <div class="row justify-content-center mb-4 d-none" id="errorRow">
    <div class="col-md-9 col-lg-8">
      <div class="alert alert-danger shadow-sm border-0 rounded-3" role="alert" id="errorAlert" style="border-left: 4px solid #dc3545 !important;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> <span id="errorMsg">Gagal memproses pertanyaan Anda.</span>
      </div>
    </div>
  </div>

  <!-- Dynamic Results Container (Injected by JS) -->
  <div id="resultsContainer"></div>
</div>

<script>
  let pollInterval = null;
  let elapsedSeconds = 0;

  document.getElementById('tanyaForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const pertanyaanInput = document.getElementById('pertanyaan');
    const pertanyaan = pertanyaanInput.value.trim();
    if (!pertanyaan) return;

    // UI Updates: Hide form elements, show loading
    document.getElementById('tanyaForm').classList.add('d-none');
    document.getElementById('loadingState').classList.remove('d-none');
    
    // Reset status & error
    document.getElementById('errorRow').classList.add('d-none');
    document.getElementById('resultsContainer').innerHTML = '';
    
    elapsedSeconds = 0;
    const statusDiv = document.getElementById('pollingStatus');
    statusDiv.textContent = 'Memulai pencarian hadits... (0s)';

    // Start timer display
    const timer = setInterval(() => {
      elapsedSeconds++;
      statusDiv.textContent = `Sedang berdiskusi dengan AI... (${elapsedSeconds}s). Mohon ditunggu, komputer lokal sedang memproses model.`;
    }, 1000);

    try {
      // 1. Submit query to postTanyaApi
      const res = await fetch('/hadits/tanya/api', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ pertanyaan })
      });
      const data = await res.json();

      if (!data.success) {
        throw new Error(data.error || 'Gagal memulai pemrosesan pertanyaan.');
      }

      const jobId = data.jobId;

      // 2. Poll for status
      pollInterval = setInterval(async () => {
        try {
          const pollRes = await fetch(`/hadits/tanya/api/status/${jobId}`);
          const pollData = await pollRes.json();

          if (!pollData.success) {
            throw new Error(pollData.error || 'Gagal mengambil status pengerjaan.');
          }

          if (pollData.done) {
            // Processing finished! Clear intervals
            clearInterval(pollInterval);
            clearInterval(timer);

            if (pollData.error) {
              showError(pollData.error);
            } else {
              renderResults(pertanyaan, pollData.jawaban, pollData.referensi, pollData.webSources || []);
            }
          }
        } catch (pollErr) {
          clearInterval(pollInterval);
          clearInterval(timer);
          showError(pollErr.message);
        }
      }, 2000);

    } catch (err) {
      clearInterval(timer);
      showError(err.message);
    }
  });

  function showError(msg) {
    document.getElementById('errorMsg').textContent = msg;
    document.getElementById('errorRow').classList.remove('d-none');
    
    // Restore form so user can retry
    document.getElementById('tanyaForm').classList.remove('d-none');
    document.getElementById('loadingState').classList.add('d-none');
  }

  function renderResults(pertanyaan, jawaban, referensi, webSources) {
    // Hide form row and loading spinner entirely
    document.getElementById('formRow').classList.add('d-none');

    // Build the references HTML
    let referencesHtml = '';
    if (referensi && referensi.length > 0) {
      referencesHtml = `
        <div class="row justify-content-center mt-4">
          <div class="col-md-9 col-lg-8">
            <h5 class="fw-bold text-secondary mb-3 border-bottom pb-2">
              <i class="fa-solid fa-book-bookmark text-success me-1"></i> Referensi Hadits Terkait (${referensi.length} ditemukan)
            </h5>
            <div class="row row-cols-1 g-3">
      `;
      
      referensi.forEach(h => {
        const formattedKitab = h.kitab ? h.kitab.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) : '';
        referencesHtml += `
          <div class="col">
            <div class="card shadow-sm border-0 rounded-3" style="background: var(--glass-bg); border-left: 3px solid var(--accent-color) !important;">
              <div class="card-header bg-transparent border-0 pt-3 pb-0 px-3 d-flex justify-content-between align-items-center">
                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1 fw-semibold" style="font-size: 0.8rem;">
                  HR. ${formattedKitab}
                </span>
                <span class="text-muted small">No. Hadits: ${h.nomor}</span>
              </div>
              <div class="card-body px-3 py-3">
                ${h.arab ? `
                  <div class="arabic-text text-end mb-3" style="font-size: 1.5rem; line-height: 3rem; color: #1f2937; direction: rtl;">
                    ${h.arab}
                  </div>
                ` : ''}
                ${h.terjemah ? `
                  <div class="text-muted small text-justify" style="line-height: 1.5rem;">
                    <span class="fw-bold text-secondary">Terjemahan:</span>
                    <div class="mt-1">${h.terjemah}</div>
                  </div>
                ` : ''}
              </div>
            </div>
          </div>
        `;
      });

      referencesHtml += `
            </div>
          </div>
        </div>
      `;
    } else {
      referencesHtml = `
        <div class="row justify-content-center mt-4">
          <div class="col-md-9 col-lg-8">
            <div class="alert alert-warning border-0 shadow-sm" role="alert">
              <i class="fa-solid fa-triangle-exclamation me-2"></i> Tidak ditemukan hadits referensi spesifik di database lokal untuk topik ini. AI menjawab menggunakan wawasan umum keislaman yang sahih.
            </div>
          </div>
        </div>
      `;
    }

    // Build the full HTML output
    const htmlOutput = `
      <!-- User's Query Card -->
      <div class="row justify-content-center mb-4">
        <div class="col-md-9 col-lg-8">
          <div class="card shadow-sm border-0 rounded-3 p-3 bg-light">
            <div class="small text-muted fw-bold mb-1"><i class="fa-solid fa-user me-1"></i> Pertanyaan Anda:</div>
            <p class="mb-0 fw-semibold text-secondary" style="font-size: 1.05rem;">"${pertanyaan}"</p>
          </div>
        </div>
      </div>

      <!-- AI Answer Card -->
      <div class="row justify-content-center mb-4">
        <div class="col-md-9 col-lg-8">
          <div class="card shadow border-0 rounded-4 overflow-hidden" style="background: #ffffff; border-top: 5px solid var(--accent-color) !important;">
            <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0 d-flex align-items-center">
              <div class="bg-success-subtle p-2 rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                <i class="fa-solid fa-robot text-success fs-5"></i>
              </div>
              <div>
                <h5 class="fw-bold text-secondary mb-0">Jawaban BaknusAI</h5>
                <small class="text-muted">Generate by BaknusAI</small>
              </div>
            </div>
            <div class="card-body px-4 py-4">
              <div class="ai-response-text" style="font-size: 1.1rem; color: #374151; line-height: 1.8rem; text-align: justify; white-space: pre-line;">
                ${jawaban}
              </div>
              
              <div class="mt-4 text-center">
                <p class="text-muted small mb-0 fst-italic"><i class="fa-solid fa-circle-info text-info me-1"></i> Ini adalah hasil penelusuran dari database hadist oleh BaknusAI Jawaban bisa saja keliru.</p>
              </div>
              
              <hr class="my-4" style="opacity: 0.1;">
              <div class="text-center">
                <button onclick="location.reload()" class="btn btn-outline-success btn-sm rounded-pill px-4 mb-3"><i class="fa-solid fa-rotate-left me-1"></i> Tanya Pertanyaan Lain</button>
                <div class="text-muted small mt-2">
                  Anda cukup puas dengan jawaban ini? jika belum silahkan bertanya langsung ke ustad ustadah di fasilitas <a href="/tanya" class="text-success fw-bold text-decoration-none">Tanya Yuk</a>.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Hadith references -->
      ${referencesHtml}

      <!-- Web Sources (Wikipedia fallback) -->
      ${webSources && webSources.length > 0 ? `
        <div class="row justify-content-center mt-3">
          <div class="col-md-9 col-lg-8">
            <div class="card border-0 rounded-3 shadow-sm" style="border-left: 3px solid #0d6efd !important; background: var(--glass-bg);">
              <div class="card-body px-4 py-3">
                <h6 class="fw-bold text-primary mb-3">
                  <i class="fa-solid fa-globe me-1"></i> Sumber Referensi Tambahan (Wikipedia)
                </h6>
                <div class="d-flex flex-column gap-2">
                  ${webSources.map(s => `
                    <div class="d-flex align-items-start gap-2">
                      <i class="fa-solid fa-link text-muted mt-1" style="font-size:0.8rem;"></i>
                      <div>
                        <a href="${s.url}" target="_blank" rel="noopener noreferrer" class="text-primary fw-semibold text-decoration-none small">${s.title}</a>
                        <div class="text-muted" style="font-size:0.8rem;">${s.snippet}</div>
                      </div>
                    </div>
                  `).join('')}
                </div>
              </div>
            </div>
          </div>
        </div>
      ` : ''}
    `;

    document.getElementById('resultsContainer').innerHTML = htmlOutput;
  }
</script>

<%- include('../partials/footer') %>
