<%- include('../partials/header') %>

<div class="row mb-4 align-items-center d-print-none animate__animated animate__fadeIn">
  <!-- Profile & Welcome -->
  <div class="col-12">
    <div class="card-glass p-3 p-sm-4 mb-4" style="background: linear-gradient(135deg, rgba(21, 128, 61, 0.08) 0%, rgba(21, 128, 61, 0.16) 100%);">
      <div class="row align-items-center">
        <div class="col-auto mb-3 mb-md-0">
          <div class="d-flex align-items-center justify-content-center rounded-circle border border-2 border-success shadow-sm text-white fw-bold fs-2" style="width: 70px; height: 70px; background-color: #15803d; overflow: hidden; flex-shrink: 0; box-shadow: 0 0 20px rgba(21, 128, 61, 0.15);">
            <img src="https://baknusmail.smkbn666.sch.id/api/auth/avatar/<%= currentUser.mailcow_email %>"
                 alt="Avatar"
                 style="width: 100%; height: 100%; object-fit: cover;"
                 onerror="this.style.display='none'; this.parentElement.innerText='<%= (currentUser.nama || 'B').charAt(0).toUpperCase() %>';" />
          </div>
        </div>
        <div class="col">
          <span class="text-secondary text-uppercase small tracking-wider font-weight-bold">Dashboard Tata Usaha (TU)</span>
          <h1 class="h2 mb-1"><%= currentUser.nama || (currentUser.profile && currentUser.profile.displayName) %></h1>
          <p class="text-secondary mb-0">
            <strong>Email:</strong> <%= currentUser.mailcow_email %> &bull; 
            <strong>Hak Akses:</strong> Staf Tata Usaha
            <% if (currentUser.profile && currentUser.profile.phoneNumber) { %>
              &bull; <strong>HP:</strong> <%= currentUser.profile.phoneNumber %>
              <% if (currentUser.profile.isPhoneVerified) { %>
                <span class="badge rounded-pill ms-1 text-success" style="font-size: 0.65rem; background-color: rgba(22, 163, 74, 0.1); border: 1px solid rgba(22, 163, 74, 0.2);"><i class="fa-solid fa-circle-check"></i> Verified</span>
              <% } %>
            <% } %>
          </p>
        </div>
        <div class="col-md-auto mt-3 mt-md-0">
          <button onclick="window.print()" class="btn btn-outline-info rounded-pill px-3">
            <i class="fa-solid fa-print me-1"></i> Cetak Laporan
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Stats Counter Grid (Hidden on Print) -->
<div class="row mb-4 d-print-none">
  <div class="col-md-6 mb-3 mb-md-0">
    <div class="card-glass stat-card">
      <h5 class="text-secondary mb-2"><i class="fa-solid fa-graduation-cap me-2 text-accent"></i> Total Siswa Terdaftar</h5>
      <h2 class="mb-0 text-accent font-weight-bold"><%= stats.totalSiswa %></h2>
      <small class="text-muted">Mengambil data user terintegrasi Mailcow</small>
    </div>
  </div>
  
  <div class="col-md-6">
    <div class="card-glass stat-card success">
      <h5 class="text-secondary mb-2"><i class="fa-solid fa-school me-2 text-success"></i> Total Kelas Aktif</h5>
      <h2 class="mb-0 text-success font-weight-bold"><%= stats.totalKelas %></h2>
      <small class="text-muted">Kelas yang telah dibuat oleh Administrator</small>
    </div>
  </div>
</div>

<!-- Report Filter Card (Hidden on Print) -->
<div class="card-glass p-4 mb-4 d-print-none">
  <h5 class="mb-3 text-secondary"><i class="fa-solid fa-filter me-2"></i> Filter Laporan</h5>
  <form action="/dashboard" method="GET" class="row g-3">
    <div class="col-md-5">
      <label for="class_id" class="form-label">Pilih Kelas</label>
      <select class="form-select" id="class_id" name="class_id" onchange="this.form.submit()">
        <option value="">-- Semua Kelas --</option>
        <% classes.forEach(c => { %>
          <option value="<%= c._id %>" <%= selectedClassId === c._id.toString() ? 'selected' : '' %>>
            <%= c.nama_kelas %> (<%= c.tahun_ajaran %>)
          </option>
        <% }) %>
      </select>
    </div>
    
    <div class="col-md-5">
      <label for="search" class="form-label">Cari Nama / NIS Siswa</label>
      <input type="text" class="form-control" id="search" name="search" placeholder="Masukkan nama atau NIS..." value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
    </div>

    <div class="col-md-2 d-flex align-items-end">
      <button type="submit" class="btn btn-primary-custom w-100 py-2">
        <i class="fa-solid fa-magnifying-glass me-1"></i> Filter
      </button>
    </div>
  </form>
</div>

<!-- Print Header (Visible ONLY on Print) -->
<div class="d-none d-print-block mb-5 text-dark">
  <div class="text-center border-bottom pb-3 mb-4">
    <h3 class="mb-1"><strong>SMK BAKTI NUSANTARA 666</strong></h3>
    <p class="mb-1 text-muted">LAPORAN CAPAIAN HAFALAN & PRAKTEK IBADAH SISWA</p>
    <small>Tanggal Cetak: <%= new Date().toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %></small>
  </div>
</div>

<!-- Recap Table Card -->
<div class="card-glass p-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0"><i class="fa-solid fa-table-list me-2 text-accent"></i> Hasil Laporan Rekapitulasi</h5>
    <span class="badge" style="background-color: var(--bg-tertiary) !important; color: var(--accent-color) !important; border: 1px solid var(--glass-border) !important; font-size: 0.85rem;"><%= recap.length %> Siswa Ditemukan</span>
  </div>

  <% if (recap && recap.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-custom align-middle">
        <thead>
          <tr>
            <th>NIS</th>
            <th>Nama Siswa</th>
            <th>Kelas</th>
            <th>Tahun Ajaran</th>
            <th class="text-center">Hafalan (Kompeten / Total)</th>
            <th class="text-center">Ibadah (Kompeten / Total)</th>
            <th class="text-center">Amalan Yaumi (Fardhu / Sunnah / Puasa)</th>
            <th class="text-end d-print-none">Riwayat Detail</th>
          </tr>
        </thead>
        <tbody>
          <% recap.forEach(row => { %>
            <tr>
              <td><strong><%= row.nis %></strong></td>
              <td><%= row.nama %></td>
              <td><span class="badge" style="background-color: var(--bg-tertiary); color: var(--text-primary); border: 1px solid var(--glass-border);"><%= row.kelas %></span></td>
              <td><span class="text-secondary small"><%= row.tahun_ajaran %></span></td>
              
              <!-- Hafalan Recap -->
              <td class="text-center">
                <span class="text-success fw-bold"><%= row.hafalan.kompeten %></span>
                <span class="text-secondary">/</span>
                <span class="text-primary"><%= row.hafalan.total %></span>
                <div class="progress mt-1 mx-auto d-print-none" style="height: 4px; max-width: 100px; background-color: var(--bg-tertiary);">
                  <div class="progress-bar bg-success" role="progressbar" style="width: <%= row.hafalan.total > 0 ? (row.hafalan.kompeten / row.hafalan.total * 100) : 0 %>%"></div>
                </div>
              </td>
              
              <!-- Ibadah Recap -->
              <td class="text-center">
                <span class="text-success fw-bold"><%= row.ibadah.kompeten %></span>
                <span class="text-secondary">/</span>
                <span class="text-primary"><%= row.ibadah.total %></span>
                <div class="progress mt-1 mx-auto d-print-none" style="height: 4px; max-width: 100px; background-color: var(--bg-tertiary);">
                  <div class="progress-bar bg-info" role="progressbar" style="width: <%= row.ibadah.total > 0 ? (row.ibadah.kompeten / row.ibadah.total * 100) : 0 %>%"></div>
                </div>
              </td>

              <!-- Amalan Yaumi Recap -->
              <td class="text-center">
                <% if (row.amalan && row.amalan.daysFilled > 0) { %>
                  <% const farduPct = row.amalan.fardu.expected > 0 ? Math.round((row.amalan.fardu.done / row.amalan.fardu.expected) * 100) : 0 %>
                  <span class="text-success fw-bold" title="Fardhu: <%= row.amalan.fardu.done %>/<%= row.amalan.fardu.expected %>"><%= farduPct %>% Fardhu</span> &bull;
                  <span class="text-info fw-bold" title="Salat Sunnah"><%= row.amalan.sunnah %> Sunnah</span> &bull;
                  <span class="text-warning fw-bold" title="Puasa Sunnah"><%= row.amalan.puasa %> Puasa</span>
                  <div class="progress mt-1 mx-auto d-print-none" style="height: 4px; max-width: 120px; background-color: var(--bg-tertiary);">
                    <div class="progress-bar bg-warning" role="progressbar" style="width: <%= farduPct %>%"></div>
                  </div>
                <% } else { %>
                  <span class="text-muted small">Belum Mengisi</span>
                <% } %>
              </td>

              <!-- Action Link -->
              <td class="text-end d-print-none">
                <div class="btn-group">
                  <a href="/hafalan/riwayat?search=<%= row.nama %>" class="btn btn-outline-secondary btn-sm me-1 rounded" title="Riwayat Hafalan">
                    <i class="fa-solid fa-microphone"></i>
                  </a>
                  <a href="/ibadah/riwayat?search=<%= row.nama %>" class="btn btn-outline-secondary btn-sm me-1 rounded" title="Riwayat Ibadah">
                    <i class="fa-solid fa-hands-praying"></i>
                  </a>
                  <a href="/amalan/detail/<%= row.id %>" class="btn btn-outline-secondary btn-sm rounded" title="Detail Amalan Yaumi">
                    <i class="fa-solid fa-calendar-check"></i>
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="text-center py-5 text-secondary">
      <i class="fa-solid fa-folder-open fa-3x mb-3 text-muted"></i>
      <p class="mb-0">Tidak ada data siswa ditemukan.</p>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
