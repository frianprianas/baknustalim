<%- include('../partials/header') %>

<div class="row mb-4 animate__animated animate__fadeIn d-print-none">
  <!-- Profile & Welcome -->
  <div class="col-12">
    <div class="card-glass p-3 p-sm-4 mb-4" style="background: linear-gradient(135deg, rgba(21, 128, 61, 0.08) 0%, rgba(21, 128, 61, 0.16) 100%);">
      <div class="row align-items-center">
        <div class="col-auto mb-3 mb-md-0">
          <div class="d-flex align-items-center justify-content-center rounded-circle border border-2 border-success shadow-sm text-white fw-bold fs-2" style="width: 70px; height: 70px; background-color: #15803d; overflow: hidden; flex-shrink: 0; box-shadow: 0 0 20px rgba(21, 128, 61, 0.15);">
            <img src="https://baknusmail.smkbn666.sch.id/api/auth/avatar/<%= currentUser.mailcow_email %>"
                 alt="Avatar"
                 style="width: 100%; height: 100%; object-fit: cover;"
                 onerror="this.style.display='none'; this.parentElement.innerText='<%= (currentUser.nama || 'B').charAt(0).toUpperCase() %>';" />
          </div>
        </div>
        <div class="col">
          <span class="text-secondary text-uppercase small tracking-wider font-weight-bold d-flex align-items-center gap-2 flex-wrap">
            Selamat Datang di <span class="arabic-title-highlight px-2 py-0.5" style="font-size: 1.15rem; font-weight: normal; line-height: 1.2;">بَاكْنُوسْ تَعْلِيمْ</span>
          </span>
          <h1 class="h2 mb-1"><%= currentUser.nama || (currentUser.profile && currentUser.profile.displayName) %></h1>
          <p class="text-secondary mb-0">
            <strong>NIP/Username:</strong> <%= currentUser.nip || currentUser.mailcow_email.split('@')[0] %> &bull; 
            <strong>Status:</strong> <%= currentUser.role === 'guru' && currentUser.is_guru_pai ? 'Guru Pendidikan Agama Islam (PAI)' : 'Guru' %>
            <% if (currentUser.profile && currentUser.profile.phoneNumber) { %>
              &bull; <strong>HP:</strong> <%= currentUser.profile.phoneNumber %>
              <% if (currentUser.profile.isPhoneVerified) { %>
                <span class="badge rounded-pill ms-1 text-success" style="font-size: 0.65rem; background-color: rgba(22, 163, 74, 0.1); border: 1px solid rgba(22, 163, 74, 0.2);"><i class="fa-solid fa-circle-check"></i> Verified</span>
              <% } %>
            <% } %>
          </p>
        </div>
        <div class="col-md-auto mt-3 mt-md-0 d-flex gap-2">
          <% if (currentUser.role === 'guru' && currentUser.is_guru_pai) { %>
            <button onclick="window.print()" class="btn btn-outline-info rounded-pill px-3">
              <i class="fa-solid fa-print me-1"></i> Cetak Laporan
            </button>
          <% } %>
          <a href="/quran" class="btn btn-secondary-custom">
            <i class="fa-solid fa-book-quran me-1"></i> Baca Al-Qur'an
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Widget Jadwal Sholat -->
<%- include('../partials/prayer_times') %>

<!-- Live Stream Alert Banner -->
<% if (activeLiveSessions && activeLiveSessions.length > 0) { %>
  <div class="row mb-4 d-print-none">
    <div class="col-12">
      <div class="alert alert-danger border-0 shadow-sm d-flex flex-wrap align-items-center justify-content-between p-3" style="background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.15) 100%); border-left: 5px solid #ef4444 !important; border-radius: 12px;">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle bg-danger text-white d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; flex-shrink: 0; box-shadow: 0 0 10px rgba(239, 68, 68, 0.4);">
            <i class="fa-solid fa-satellite-dish fa-lg animate__animated animate__pulse animate__infinite"></i>
          </div>
          <div>
            <h5 class="alert-heading text-danger mb-0 font-weight-bold">Kajian Islami Sedang Live!</h5>
            <p class="mb-0 text-secondary small">
              <strong><%= activeLiveSessions[0].nama_guru %></strong> sedang membawakan kajian: <em>"<%= activeLiveSessions[0].topik %>"</em>
            </p>
          </div>
        </div>
        <a href="/live/room/<%= activeLiveSessions[0].nama_room %>" class="btn btn-danger btn-sm rounded-pill px-4 py-2 mt-2 mt-sm-0" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border: none;">
          <i class="fa-solid fa-video me-1"></i> Ikut Kajian
        </a>
      </div>
    </div>
  </div>
<% } else if (currentUser.role === 'guru' && currentUser.is_guru_pai) { %>
  <!-- Quick Start Kajian Live Promo for PAI Teachers -->
  <div class="row mb-4 d-print-none">
    <div class="col-12">
      <div class="card-glass p-3 border-0 d-flex flex-wrap align-items-center justify-content-between" style="background: linear-gradient(135deg, rgba(16, 185, 129, 0.05) 0%, rgba(16, 185, 129, 0.1) 100%); border-radius: 12px;">
        <div class="d-flex align-items-center gap-3">
          <div class="rounded-circle text-success bg-success-glow d-flex align-items-center justify-content-center border border-success" style="width: 45px; height: 45px; flex-shrink: 0;">
            <i class="fa-solid fa-tower-broadcast fa-lg"></i>
          </div>
          <div>
            <h5 class="mb-0 text-primary font-weight-bold">Adakan Kajian Live Hari Ini?</h5>
            <p class="mb-0 text-secondary small">Siarkan langsung video bimbingan ibadah atau tadarus Al-Qur'an untuk disimak oleh seluruh siswa.</p>
          </div>
        </div>
        <a href="/live" class="btn btn-outline-success btn-sm rounded-pill px-4 py-2 mt-2 mt-sm-0">
          <i class="fa-solid fa-plus me-1"></i> Buat Kajian Live
        </a>
      </div>
    </div>
  </div>
<% } %>

<% if (currentUser.role === 'guru' && currentUser.is_guru_pai) { %>
<!-- Print Header (Visible ONLY on Print) -->
<div class="d-none d-print-block mb-5 text-dark">
  <div class="text-center border-bottom pb-3 mb-4">
    <h3 class="mb-1"><strong>SMK BAKTI NUSANTARA 666</strong></h3>
    <p class="mb-1 text-muted">LAPORAN REKAPITULASI CAPAIAN GURU PAI</p>
    <p class="mb-1"><strong>Nama Guru:</strong> <%= currentUser.nama || (currentUser.profile && currentUser.profile.displayName) %> &nbsp;|&nbsp; <strong>NIP:</strong> <%= currentUser.nip || '-' %></p>
    <small>Tanggal Cetak: <%= new Date().toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %></small>
  </div>
</div>

<!-- Stats Counter Grid -->
<div class="row mb-4">
  <!-- Assigned Classes -->
  <div class="col-md-4 mb-3 mb-md-0">
    <div class="card-glass stat-card">
      <h5 class="text-secondary mb-2"><i class="fa-solid fa-school me-2 text-accent"></i> Kelas Diampu</h5>
      <h2 class="mb-0 text-accent font-weight-bold"><%= classes.length %></h2>
      <small class="text-muted">Total kelas aktif tahun ajaran ini</small>
    </div>
  </div>

  <!-- Total Students -->
  <div class="col-md-4 mb-3 mb-md-0">
    <div class="card-glass stat-card success">
      <h5 class="text-secondary mb-2"><i class="fa-solid fa-users me-2 text-success"></i> Jumlah Siswa</h5>
      <h2 class="mb-0 text-success font-weight-bold"><%= stats.studentCount %></h2>
      <small class="text-muted">Total siswa dalam kelas yang diampu</small>
    </div>
  </div>

  <!-- Graded Counts -->
  <div class="col-md-4">
    <div class="card-glass stat-card warning">
      <h5 class="text-secondary mb-2"><i class="fa-solid fa-signature me-2 text-warning"></i> Total Penilaian Anda</h5>
      <h2 class="mb-0 text-warning font-weight-bold"><%= stats.hafalanGraded + stats.ibadahGraded %></h2>
      <small class="text-muted"><%= stats.hafalanGraded %> Hafalan &bull; <%= stats.ibadahGraded %> Praktek Ibadah</small>
    </div>
  </div>
</div>

<!-- Academic & Q&A Stats Recapitulation -->
<h4 class="mb-3 font-weight-bold text-primary"><i class="fa-solid fa-chart-line me-2 text-accent"></i> Rekapitulasi Capaian Sekolah & Tanya Jawab</h4>
<div class="row mb-4">
  <!-- Hafalan Stats -->
  <div class="col-md-4 mb-3 mb-md-0">
    <div class="card-glass p-3 h-100">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="text-secondary mb-0"><i class="fa-solid fa-book-open me-2 text-accent"></i> Evaluasi Hafalan (Sekolah)</h6>
        <span class="badge px-2 py-1 small" style="background-color: rgba(22, 163, 74, 0.1); color: var(--accent-color); border: 1px solid rgba(22, 163, 74, 0.2);">Kompeten</span>
      </div>
      <div class="row align-items-center">
        <div class="col-6 border-end border-light">
          <h2 class="mb-0 text-primary font-weight-bold"><%= stats.totalHafalan %></h2>
          <small class="text-muted">Total Setoran</small>
        </div>
        <div class="col-6 ps-3">
          <h3 class="mb-0 text-success font-weight-bold">
            <%= stats.totalHafalan > 0 ? Math.round((stats.kompetenHafalan / stats.totalHafalan) * 100) : 0 %>%
          </h3>
          <small class="text-muted"><%= stats.kompetenHafalan %> Setoran Lulus</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Ibadah Stats -->
  <div class="col-md-4 mb-3 mb-md-0">
    <div class="card-glass p-3 h-100">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="text-secondary mb-0"><i class="fa-solid fa-hands-praying me-2 text-accent"></i> Praktek Ibadah (Sekolah)</h6>
        <span class="badge px-2 py-1 small" style="background-color: rgba(22, 163, 74, 0.1); color: var(--accent-color); border: 1px solid rgba(22, 163, 74, 0.2);">Kompeten</span>
      </div>
      <div class="row align-items-center">
        <div class="col-6 border-end border-light">
          <h2 class="mb-0 text-primary font-weight-bold"><%= stats.totalIbadah %></h2>
          <small class="text-muted">Total Penilaian</small>
        </div>
        <div class="col-6 ps-3">
          <h3 class="mb-0 text-success font-weight-bold">
            <%= stats.totalIbadah > 0 ? Math.round((stats.kompetenIbadah / stats.totalIbadah) * 100) : 0 %>%
          </h3>
          <small class="text-muted"><%= stats.kompetenIbadah %> Uji Lulus</small>
        </div>
      </div>
    </div>
  </div>

  <!-- Q&A Stats -->
  <div class="col-md-4">
    <div class="card-glass p-3 h-100">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="text-secondary mb-0"><i class="fa-solid fa-comments me-2 text-accent"></i> Tanya Yuk! Q&A</h6>
        <span class="badge px-2 py-1 small" style="background-color: rgba(245, 158, 11, 0.1); color: #d97706; border: 1px solid rgba(245, 158, 11, 0.2);"><%= stats.unansweredQuestions %> Pending</span>
      </div>
      <div class="row align-items-center">
        <div class="col-6 border-end border-light">
          <h2 class="mb-0 text-primary font-weight-bold"><%= stats.totalQuestions %></h2>
          <small class="text-muted">Diajukan</small>
        </div>
        <div class="col-6 ps-3">
          <h3 class="mb-0 text-info font-weight-bold">
            <%= stats.answeredByMe %>
          </h3>
          <small class="text-muted">Anda Jawab</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Main Area -->
<div class="row">
  <!-- Class list & Shortcuts -->
  <div class="col-lg-8 mb-4">
    <div class="card-glass h-100">
      <h5 class="mb-4"><i class="fa-solid fa-list-check me-2 text-accent"></i> Kelas yang Anda Ampu</h5>
      
      <% if (classes && classes.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Nama Kelas</th>
                <th>Tahun Ajaran</th>
                <th class="text-end d-print-none">Aksi Cepat</th>
              </tr>
            </thead>
            <tbody>
              <% classes.forEach(c => { %>
                <tr>
                  <td>
                    <strong><%= c.nama_kelas %></strong>
                  </td>
                  <td>
                    <span class="text-secondary"><%= c.tahun_ajaran %></span>
                  </td>
                  <td class="text-end d-print-none">
                    <div class="btn-group">
                      <a href="/hafalan/input" class="btn btn-outline-info btn-sm me-2 rounded">
                        <i class="fa-solid fa-microphone me-1"></i> Nilai Hafalan
                      </a>
                      <a href="/ibadah/input" class="btn btn-outline-success btn-sm rounded">
                        <i class="fa-solid fa-hands-praying me-1"></i> Nilai Ibadah
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-5 text-secondary">
          <i class="fa-solid fa-school-circle-exclamation fa-3x mb-3 text-muted"></i>
          <p class="mb-0">Anda belum ditugaskan ke kelas manapun oleh Administrator.</p>
          <small class="text-muted">Hubungi Tata Usaha atau Admin untuk penempatan mengajar.</small>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Grading Shortcuts Panel -->
  <div class="col-lg-4 mb-4 d-print-none">
    <div class="card-glass h-100 d-flex flex-column justify-content-between">
      <div>
        <h5 class="mb-3"><i class="fa-solid fa-bolt me-2 text-warning"></i> Menu Penilaian</h5>
        <p class="text-secondary small">Gunakan tombol di bawah ini untuk langsung menuju lembar penilaian hafalan Al-Qur'an atau praktek ibadah harian siswa.</p>
      </div>

      <div class="d-grid gap-3 mt-4">
        <a href="/hafalan/input" class="btn btn-primary-custom py-3 text-start d-flex justify-content-between align-items-center">
          <span><i class="fa-solid fa-microphone me-2"></i> Input Hafalan Qur'an</span>
          <i class="fa-solid fa-chevron-right"></i>
        </a>
        <a href="/ibadah/input" class="btn btn-success btn-lg py-3 text-start d-flex justify-content-between align-items-center border-0" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 10px; color: #fff;">
          <span><i class="fa-solid fa-hands-praying me-2"></i> Input Praktek Ibadah</span>
          <i class="fa-solid fa-chevron-right"></i>
        </a>
        <a href="/hafalan/riwayat" class="btn btn-secondary-custom py-2.5 text-start d-flex justify-content-between align-items-center">
          <span><i class="fa-solid fa-list me-2"></i> Lihat Semua Riwayat Nilai</span>
          <i class="fa-solid fa-chevron-right"></i>
        </a>
      </div>
    </div>
  </div>
</div>
<% } else { %>
<!-- Simplified Regular Teacher Content -->
<div class="row">
  <div class="col-12 col-md-6 mb-4 animate__animated animate__fadeInUp">
    <div class="card-glass p-4 h-100 d-flex flex-column justify-content-between text-center align-items-center">
      <div class="mb-3">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 80px; height: 80px; background-color: rgba(21, 128, 61, 0.08); border: 1px solid var(--glass-border); box-shadow: 0 0 20px rgba(21, 128, 61, 0.1);">
          <i class="fa-solid fa-book-quran fa-3x text-accent"></i>
        </div>
        <h4>Membaca Al-Qur'an</h4>
        <p class="text-secondary small mb-0">Akses mushaf Al-Qur'an digital lengkap dengan terjemahan resmi Kemenag RI dan fitur penanda (bookmarks) untuk mendukung tadarus harian Anda.</p>
      </div>
      <a href="/quran" class="btn btn-primary-custom w-100 py-2.5">
        <i class="fa-solid fa-book-open me-2"></i> Mulai Membaca
      </a>
    </div>
  </div>
  
  <div class="col-12 col-md-6 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
    <div class="card-glass p-4 h-100 d-flex flex-column justify-content-between text-center align-items-center">
      <div class="mb-3">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 80px; height: 80px; background-color: rgba(21, 128, 61, 0.08); border: 1px solid var(--glass-border); box-shadow: 0 0 20px rgba(21, 128, 61, 0.1);">
          <i class="fa-solid fa-comments fa-3x text-accent"></i>
        </div>
        <h4>Tanya Jawab Islami</h4>
        <p class="text-secondary small mb-0">Ajukan pertanyaan keagamaan atau berpartisipasi dalam ruang konsultasi ibadah dan diskusi keislaman bersama tim Guru PAI.</p>
      </div>
      <a href="/tanya" class="btn btn-primary-custom w-100 py-2.5">
        <i class="fa-solid fa-comments me-2"></i> Buka Tanya Yuk!
      </a>
    </div>
  </div>
</div>
<% } %>

<%- include('../partials/footer') %>
