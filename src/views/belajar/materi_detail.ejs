<%- include('../partials/header') %>

<div class="row justify-content-center animate__animated animate__fadeIn">
  <div class="col-lg-8 col-md-10">

    <!-- Header Navigation Back -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
      <div class="d-flex align-items-center">
        <a href="/belajar/kategori/<%= materi.kategori %>" class="btn btn-outline-light rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
          <i class="fa-solid fa-arrow-left"></i>
        </a>
        <div>
          <span class="text-secondary small text-uppercase fw-bold">Belajar <%= kategoriName %></span>
          <h1 class="h3 mb-0 text-success"><%= materi.judul %></h1>
        </div>
      </div>
      
      <% if (currentUser.role === 'admin' || (currentUser.role === 'guru' && materi.guru_id && materi.guru_id._id.toString() === currentUser.id)) { %>
        <div class="d-flex gap-2">
          <a href="/belajar/input?edit_id=<%= materi._id %>" class="btn btn-outline-primary btn-sm rounded-pill px-3">
            <i class="fa-solid fa-pen me-1"></i> Edit
          </a>
          <form action="/belajar/delete/<%= materi._id %>" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus materi ini?');" class="d-inline">
            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
              <i class="fa-solid fa-trash me-1"></i> Hapus
            </button>
          </form>
        </div>
      <% } %>
    </div>

    <% if (typeof earnedPoints !== 'undefined' && earnedPoints) { %>
      <div class="alert alert-success border-0 text-center mb-4 py-3 animate__animated animate__bounceIn" style="background: rgba(22, 163, 74, 0.15); color: #16a34a; border: 1px solid rgba(22, 163, 74, 0.3) !important; border-radius: 12px; font-weight: 500;">
        <i class="fa-solid fa-gift me-2 fs-5"></i> Selamat! Anda memperoleh <strong class="text-white bg-success px-2 py-1 rounded">+5 Poin</strong> karena telah membaca materi ini.
      </div>
    <% } %>

    <!-- Article Content Card -->
    <div class="card-glass p-4 p-md-5 mb-5">
      <!-- Metadata -->
      <div class="d-flex flex-wrap align-items-center gap-3 text-secondary small border-bottom pb-3 mb-4" style="border-color: var(--glass-border) !important;">
        <span class="d-flex align-items-center gap-1">
          <i class="fa-solid fa-user-tie text-success"></i> Diterbitkan oleh: <strong><%= materi.guru_id ? materi.guru_id.nama : 'Guru PAI' %></strong>
        </span>
        <span class="d-flex align-items-center gap-1">
          <i class="fa-solid fa-calendar-day"></i> <%= new Date(materi.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
        </span>
      </div>

      <!-- Main Body Text -->
      <div class="text-secondary leading-relaxed" style="font-size: 1.08rem; white-space: pre-wrap; word-wrap: break-word;"><%= materi.konten %></div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
