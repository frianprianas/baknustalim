<%- include('../partials/header') %>

<div class="row justify-content-center animate__animated animate__fadeIn">
  <div class="col-lg-10 col-md-12">

    <!-- Header Summary -->
    <div class="card-glass p-4 mb-4" style="background: linear-gradient(135deg, rgba(21, 128, 61, 0.08) 0%, rgba(21, 128, 61, 0.16) 100%);">
      <div class="row align-items-center">
        <div class="col-auto">
          <div class="bg-success text-white p-3 rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 55px; height: 55px;">
            <i class="fa-solid fa-book-open-reader fs-4"></i>
          </div>
        </div>
        <div class="col">
          <span class="text-secondary text-uppercase small tracking-wider font-weight-bold">Portal Edukasi</span>
          <h1 class="h3 mb-0 text-success">Belajar Islam</h1>
          <p class="text-secondary mb-0">Pelajari ilmu Tajwid, Aqidah, Fiqih Ibadah, dan Akhlak secara interaktif.</p>
        </div>
      </div>
    </div>

    <!-- Category Cards Grid -->
    <div class="row g-4 justify-content-center">
      <% categories.forEach(cat => { %>
        <% 
          let link = cat.id === 'tajwid' ? '/belajar/tajwid' : `/belajar/kategori/${cat.id}`;
        %>
        <div class="col-md-6">
          <div class="card-glass h-100 p-4 border-top border-4 <%= cat.color %>" style="transition: transform 0.25s, box-shadow 0.25s;">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div class="d-flex align-items-center gap-3">
                <div class="rounded-circle d-flex align-items-center justify-content-center <%= cat.badgeColor %>" style="width: 48px; height: 48px; font-size: 1.25rem;">
                  <i class="fa-solid <%= cat.icon %>"></i>
                </div>
                <h4 class="fw-bold mb-0 text-primary"><%= cat.name %></h4>
              </div>
            </div>
            
            <p class="text-secondary mb-4" style="font-size: 0.95rem; min-height: 50px;"><%= cat.desc %></p>
            
            <div class="d-flex justify-content-between align-items-center mt-auto">
              <a href="<%= link %>" class="btn btn-primary-custom rounded-pill px-4">
                Mulai Belajar <i class="fa-solid fa-chevron-right ms-2 fs-7"></i>
              </a>
              <% if (cat.id !== 'tajwid' && (currentUser.role === 'admin' || (currentUser.role === 'guru' && currentUser.is_guru_pai))) { %>
                <a href="/belajar/input?kategori=<%= cat.id %>" class="btn btn-outline-success btn-sm rounded-pill px-3">
                  <i class="fa-solid fa-plus me-1"></i> Tulis Materi
                </a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
