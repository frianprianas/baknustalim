<%- include('../partials/header') %>

<div class="row justify-content-center animate__animated animate__fadeIn">
  <div class="col-lg-8 col-md-10">

    <!-- Header Navigation Back -->
    <div class="d-flex align-items-center mb-4">
      <a href="/belajar" class="btn btn-outline-light rounded-circle me-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <span class="text-secondary small text-uppercase fw-bold">Portal Belajar Islam</span>
        <h1 class="h3 mb-0 text-success"><%= materi ? 'Edit Materi Belajar' : 'Tulis Materi Belajar Baru' %></h1>
      </div>
    </div>

    <!-- Error Callout -->
    <% if (error) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 card-glass mb-4" role="alert" style="background: rgba(220, 38, 38, 0.15); color: #dc2626; border: 1px solid rgba(220, 38, 38, 0.3) !important;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> <%= error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Form Card -->
    <div class="card-glass p-4 p-md-5 mb-5">
      <form action="/belajar/input" method="POST">
        <% if (materi && (materi._id || materi.id)) { %>
          <input type="hidden" name="id" value="<%= materi._id || materi.id %>">
        <% } %>

        <!-- Kategori Select -->
        <div class="mb-4">
          <label for="kategori" class="form-label fw-bold text-secondary">Kategori Kajian</label>
          <select name="kategori" id="kategori" class="form-select bg-transparent text-primary border-secondary-subtle" required style="border: 1px solid var(--glass-border) !important; color: var(--text-primary) !important;">
            <option value="" disabled <%= !materi ? 'selected' : '' %>>-- Pilih Kategori --</option>
            <% Object.keys(categories).forEach(key => { %>
              <option value="<%= key %>" <%= (materi && (materi.kategori === key)) ? 'selected' : '' %>><%= categories[key] %></option>
            <% }) %>
          </select>
          <div class="form-text text-muted">Materi Tajwid bersifat statis dari sistem. Guru PAI dapat mengunggah materi di tiga kategori di atas.</div>
        </div>

        <!-- Judul Input -->
        <div class="mb-4">
          <label for="judul" class="form-label fw-bold text-secondary">Judul Materi</label>
          <input type="text" class="form-control bg-transparent text-primary" id="judul" name="judul" value="<%= materi ? materi.judul : '' %>" placeholder="Masukkan judul materi..." required style="border: 1px solid var(--glass-border) !important; color: var(--text-primary) !important;">
        </div>

        <!-- Konten Textarea -->
        <div class="mb-4">
          <label for="konten" class="form-label fw-bold text-secondary">Konten / Isi Materi</label>
          <textarea class="form-control bg-transparent text-primary" id="konten" name="konten" rows="12" placeholder="Tulis penjelasan lengkap materi di sini..." required style="border: 1px solid var(--glass-border) !important; color: var(--text-primary) !important; line-height: 1.6;"><%= materi ? materi.konten : '' %></textarea>
        </div>

        <!-- Submit Button -->
        <div class="d-flex justify-content-end gap-2 mt-4">
          <a href="/belajar" class="btn btn-outline-secondary rounded-pill px-4">Batal</a>
          <button type="submit" class="btn btn-success rounded-pill px-4">
            <i class="fa-solid fa-cloud-arrow-up me-2"></i> <%= materi ? 'Simpan Perubahan' : 'Terbitkan Materi' %>
          </button>
        </div>
      </form>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
