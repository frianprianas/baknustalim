<%- include('../partials/header') %>

<style>
  body {
    background-image: linear-gradient(rgba(244, 251, 247, 0.82), rgba(244, 251, 247, 0.88)), url('/img/ngaji.png') !important;
    background-size: cover !important;
    background-position: center !important;
    background-repeat: no-repeat !important;
    background-attachment: fixed !important;
  }
  body::before {
    background: none !important;
  }
</style>

<div class="row justify-content-center align-items-center" style="min-height: calc(80vh - 100px);">
  <div class="col-md-6 col-lg-5">
    
    <!-- Outer Glow Container -->
    <div class="position-relative">
      <div class="position-absolute top-50 start-50 translate-middle w-100 h-100 rounded-5" style="background: radial-gradient(circle, rgba(21, 128, 61, 0.12) 0%, rgba(21, 128, 61, 0) 70%); filter: blur(30px); z-index: -1;"></div>
      
      <div class="card-glass p-3 p-sm-4 p-md-5">
        <div class="text-center mb-4">
          <div class="mb-3">
            <img src="/img/baknus_talim_calligraphy.png" alt="Baknus Ta'lim" style="max-height: 85px; width: auto; filter: drop-shadow(0 4px 15px rgba(21, 128, 61, 0.22));" />
          </div>
          <span class="text-accent d-block mb-3 fw-bold" style="font-size: 1.15rem; letter-spacing: 0.5px;">بَاكْنُوسْ تَعْلِيمْ <span class="text-secondary small">(BaknusTa'lim)</span></span>
          <p class="text-secondary small">Evaluasi Hafalan & Praktek Ibadah Siswa</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger border-0 small text-center mb-4 py-2" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2) !important;">
            <i class="fa-solid fa-triangle-exclamation me-1"></i> <%= error %>
          </div>
        <% } %>

        <form action="/auth/login" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label">Username / Email Mailcow</label>
            <div class="input-group">
              <span class="input-group-text bg-tertiary border-secondary text-secondary"><i class="fa-solid fa-user"></i></span>
              <input type="text" class="form-control border-secondary" id="email" name="email" value="<%= email %>" placeholder="Username (misal: dwi.lestari atau 222310123)" required autofocus>
            </div>
            <div class="form-text text-muted small" style="font-size: 0.75rem;">Cukup masukkan bagian depan email Anda (otomatis ditambahkan @smk.baktinusantara666.sch.id).</div>
          </div>

          <div class="mb-4">
            <label for="password" class="form-label">Password</label>
            <div class="input-group">
              <span class="input-group-text bg-tertiary border-secondary text-secondary"><i class="fa-solid fa-lock"></i></span>
              <input type="password" class="form-control border-secondary" id="password" name="password" placeholder="Password email Anda" required>
            </div>
            <div class="form-text text-muted small" style="font-size: 0.75rem;">Password sama dengan password SOGo/Webmail Mailcow Anda.</div>
          </div>

          <button type="submit" class="btn btn-primary-custom w-100 py-2.5 mb-3">
            <i class="fa-solid fa-right-to-bracket me-2"></i> Masuk Sekarang
          </button>
          
          <div class="text-center">
            <span class="text-muted small">Kembali ke portal utama <a href="https://smk.baktinusantara666.sch.id" target="_blank" class="highlight-school text-decoration-none">SMK Bakti Nusantara 666</a></span>
          </div>
        </form>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
