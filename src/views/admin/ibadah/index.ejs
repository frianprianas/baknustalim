<%- include('../../partials/header') %>

<div class="row mb-4 animate__animated animate__fadeIn">
  <div class="col-12">
    <h1 class="h2 mb-1"><i class="fa-solid fa-list-check me-2 text-accent"></i> Kelola Jenis Ibadah</h1>
    <p class="text-secondary mb-0">Kelola master data jenis ibadah yang dievaluasi dalam program praktek ibadah.</p>
  </div>
</div>

<div class="row">
  <!-- Create form (Left) -->
  <div class="col-lg-4 mb-4">
    <div class="card-glass p-4 sticky-top" style="top: 90px; z-index: 10;">
      <h5 class="mb-4"><i class="fa-solid fa-circle-plus text-accent me-1"></i> Tambah Jenis Ibadah</h5>
      
      <form action="/admin/ibadah/create" method="POST">
        <div class="mb-3">
          <label for="nama_ibadah" class="form-label">Nama Praktek Ibadah</label>
          <input type="text" class="form-control border-secondary" id="nama_ibadah" name="nama_ibadah" placeholder="Contoh: Sholat Dzuhur, Adzan, Wudhu..." required>
        </div>

        <div class="mb-4">
          <label for="deskripsi" class="form-label">Deskripsi / Kriteria (Opsional)</label>
          <textarea class="form-control border-secondary" id="deskripsi" name="deskripsi" rows="3" placeholder="Masukkan kriteria kompetensi..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary-custom w-100">
          <i class="fa-solid fa-save me-1"></i> Simpan
        </button>
      </form>
    </div>
  </div>

  <!-- Master Data Table (Right) -->
  <div class="col-lg-8 mb-4">
    <div class="card-glass p-4">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0"><i class="fa-solid fa-database me-2 text-accent"></i> Master Data Ibadah</h5>
        <span class="badge bg-dark border border-secondary text-accent px-3 py-2"><%= list.length %> Jenis Ibadah</span>
      </div>

      <% if (list && list.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Nama Ibadah</th>
                <th>Deskripsi / Kriteria</th>
                <th>Status</th>
                <th class="text-end">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% list.forEach(item => { %>
                <tr>
                  <td>
                    <strong class="text-light"><%= item.nama_ibadah %></strong>
                  </td>
                  <td>
                    <span class="text-secondary small"><%= item.deskripsi || '-' %></span>
                  </td>
                  <td>
                    <% if (item.is_active) { %>
                      <span class="badge bg-success-glow border border-success text-success small" style="background: rgba(16, 185, 129, 0.15);"><i class="fa-solid fa-eye me-1"></i> Aktif</span>
                    <% } else { %>
                      <span class="badge bg-dark border border-secondary text-muted small"><i class="fa-solid fa-eye-slash me-1"></i> Nonaktif</span>
                    <% } %>
                  </td>
                  <td class="text-end">
                    <div class="btn-group">
                      <!-- Trigger Edit Modal -->
                      <button type="button" class="btn btn-outline-info btn-sm me-2 rounded px-2.5" data-bs-toggle="modal" data-bs-target="#editModal<%= item._id %>">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                      </button>
                      <form action="/admin/ibadah/delete/<%= item._id %>" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin menghapus jenis ibadah ini? Tindakan ini akan menghapus semua riwayat penilaian ibadah terkait di database.')" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm rounded px-2.5">
                          <i class="fa-solid fa-trash-can"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>

                <!-- EDIT MODAL FOR THIS ITEM -->
                <div class="modal fade" id="editModal<%= item._id %>" tabindex="-1" aria-labelledby="editModalLabel<%= item._id %>" aria-hidden="true">
                  <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-secondary text-light border-secondary shadow-lg" style="background-color: var(--bg-secondary) !important; border-radius: 16px;">
                      <div class="modal-header border-secondary">
                        <h5 class="modal-title" id="editModalLabel<%= item._id %>"><i class="fa-solid fa-pen-to-square text-accent me-1"></i> Edit Jenis Ibadah</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <form action="/admin/ibadah/edit/<%= item._id %>" method="POST">
                        <div class="modal-body">
                          <div class="mb-3">
                            <label for="edit_nama_ibadah<%= item._id %>" class="form-label">Nama Praktek Ibadah</label>
                            <input type="text" class="form-control border-secondary" id="edit_nama_ibadah<%= item._id %>" name="nama_ibadah" value="<%= item.nama_ibadah %>" required>
                          </div>
                          <div class="mb-3">
                            <label for="edit_deskripsi<%= item._id %>" class="form-label">Deskripsi / Kriteria</label>
                            <textarea class="form-control border-secondary" id="edit_deskripsi<%= item._id %>" name="deskripsi" rows="3"><%= item.deskripsi %></textarea>
                          </div>
                          <div class="form-check form-switch mt-3">
                            <input class="form-check-input" type="checkbox" role="switch" id="edit_is_active<%= item._id %>" name="is_active" <%= item.is_active ? 'checked' : '' %>>
                            <label class="form-check-label text-secondary fw-medium" for="edit_is_active<%= item._id %>">Set Status Aktif</label>
                          </div>
                        </div>
                        <div class="modal-footer border-secondary">
                          <button type="button" class="btn btn-secondary-custom" data-bs-dismiss="modal">Batal</button>
                          <button type="submit" class="btn btn-primary-custom">Simpan Perubahan</button>
                        </div>
                      </form>
                    </div>
                  </div>
                </div>

              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-5 text-secondary">
          <i class="fa-solid fa-database fa-3x mb-3 text-muted"></i>
          <p class="mb-0">Belum ada jenis ibadah terdaftar.</p>
          <small class="text-muted">Gunakan form di sebelah kiri untuk menambah jenis ibadah.</small>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
