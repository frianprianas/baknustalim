<%- include('../partials/header') %>

<div class="row mb-4 animate__animated animate__fadeIn">
  <div class="col-12 text-center my-4">
    <span class="text-accent text-uppercase small font-weight-bold">
      <i class="fa-solid fa-people-group me-1"></i> Ibadah Kolektif
    </span>
    <h1 class="h1 mb-2 font-weight-bold">Ngaji Bareng</h1>
    <p class="text-secondary mx-auto" style="max-width: 600px;">
      Mari membaca Al-Qur'an bersama-sama secara real-time. Setiap ayat yang Anda dan rekan Anda baca akan saling terhubung.
    </p>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-lg-10">

    <!-- Success & Error Alert Messages -->
    <% if (successMessage) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 rounded-3 shadow-sm mb-4" role="alert">
        <i class="fa-solid fa-circle-check me-2"></i><%= successMessage %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
    <% if (errorMessage) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 rounded-3 shadow-sm mb-4" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-2"></i><%= errorMessage %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <!-- Active Sesi Ngaji Bareng Panel -->
    <div class="mb-5">
      <% if (activeSession) { %>
        <div class="card-glass p-4 border border-success" style="background: linear-gradient(135deg, rgba(34, 197, 94, 0.04) 0%, rgba(34, 197, 94, 0.08) 100%);">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
              <span class="badge bg-success rounded-pill px-3 py-1.5 animate__animated animate__pulse animate__infinite mb-3">
                <i class="fa-solid fa-circle me-1" style="font-size: 0.75em;"></i> SESI AKTIF
              </span>
              <h3 class="h4 font-weight-bold text-primary mb-1">Sesi Ngaji Bareng Sedang Berlangsung!</h3>
              <p class="text-secondary small mb-0">
                <i class="fa-solid fa-user me-1 text-accent"></i> Dimulai oleh: <strong><%= activeSession.creator_name %></strong>
              </p>
              <p class="text-secondary small">
                <i class="fa-solid fa-clock me-1 text-accent"></i> Waktu Selesai: <strong><%= new Date(activeSession.waktu_selesai).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) %> WIB</strong> (Maksimal 90 Menit)
              </p>
            </div>

            <!-- Countdown Timer & Actions -->
            <div class="text-center text-md-end">
              <div class="mb-3">
                <span class="small text-muted d-block">Sisa Waktu Sesi:</span>
                <span id="session-countdown" class="h3 font-weight-bold text-success border border-success rounded-pill px-3 py-1 bg-white shadow-sm" data-endtime="<%= activeSession.waktu_selesai.toISOString() %>">
                  00:00:00
                </span>
              </div>
              <div class="d-flex gap-2 justify-content-md-end">
                <a href="/quran" class="btn btn-success rounded-pill px-4 shadow-sm" style="background: var(--accent-color); border: none;">
                  <i class="fa-solid fa-book-open me-2"></i> Mulai Baca Al-Qur'an
                </a>
                
                <% if (currentUser.id === activeSession.created_by._id.toString() || currentUser.role === 'admin') { %>
                  <form action="/quran/ngajibareng/stop/<%= activeSession._id %>" method="POST" onsubmit="return confirm('Apakah Anda yakin ingin mengakhiri sesi Ngaji Bareng ini?');">
                    <button type="submit" class="btn btn-outline-danger rounded-pill px-3">
                      <i class="fa-solid fa-stop me-1"></i> Akhiri Sesi
                    </button>
                  </form>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Real-Time Activity Feed Inside Active Session -->
          <div class="mt-4 pt-4 border-top border-light">
            <h5 class="font-weight-bold text-primary mb-3">
              <i class="fa-solid fa-wave-square me-2 text-accent"></i> Aktivitas Ngaji Real-Time
            </h5>
            <div id="ngajiActivityFeed" class="p-3 rounded overflow-auto" style="background-color: rgba(255,255,255,0.4); max-height: 250px; min-height: 120px; border: 1px solid var(--glass-border);">
              <div class="text-center py-4 text-muted small" id="noActivityPlaceholder">
                <i class="fa-solid fa-book-quran fa-2x mb-2 text-muted-custom animate__animated animate__pulse animate__infinite"></i>
                <p class="mb-0">Menunggu teman-teman mulai membaca Al-Qur'an...</p>
                <p class="text-xs text-muted">Aktivitas membaca ayat dari semua pengguna akan muncul langsung di sini.</p>
              </div>
            </div>
          </div>
        </div>
      <% } else { %>
        <div class="card-glass p-5 text-center">
          <i class="fa-solid fa-users-slash fa-3x mb-3 text-muted"></i>
          <h4 class="font-weight-bold text-primary mb-2">Tidak Ada Sesi Ngaji Bareng</h4>
          <p class="text-secondary mx-auto mb-4" style="max-width: 500px;">
            Saat ini tidak ada sesi Ngaji Bareng yang aktif. Anda dapat memulai sesi baru untuk mengundang siswa, guru, dan staf TU lainnya membaca Al-Qur'an bersama.
          </p>
          <% const isAdmin = currentUser.role === 'admin'; %>
          <% const isGuruPAI = currentUser.role === 'guru' && currentUser.is_guru_pai; %>
          <% if (isAdmin || isGuruPAI) { %>
            <form action="/quran/ngajibareng/start" method="POST" class="d-inline-block">
              <button type="submit" class="btn btn-primary-custom px-4 py-2.5 rounded-pill shadow-sm">
                <i class="fa-solid fa-circle-play me-2"></i> Mulai Sesi Ngaji Bareng (90 Menit)
              </button>
            </form>
          <% } else { %>
            <div class="alert alert-info border-0 rounded-3 small d-inline-block px-4 py-2 mb-0">
              <i class="fa-solid fa-info-circle me-2"></i> Hubungi Guru PAI atau Admin untuk memulai sesi Ngaji Bareng.
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <!-- Riwayat Sesi Ngaji Bareng -->
    <div>
      <h3 class="h4 font-weight-bold text-primary mb-4">
        <i class="fa-solid fa-clock-rotate-left me-2 text-accent"></i> Riwayat Ngaji Bareng
      </h3>

      <% if (endedSessions && endedSessions.length > 0) { %>
        <div class="card-glass p-0 overflow-hidden">
          <div class="table-responsive">
            <table class="table table-custom align-middle mb-0">
              <thead>
                <tr>
                  <th class="ps-4">Dimulai Oleh</th>
                  <th>Tanggal</th>
                  <th>Waktu Sesi</th>
                  <th class="text-end pe-4">Status</th>
                </tr>
              </thead>
              <tbody>
                <% endedSessions.forEach(session => { %>
                  <tr>
                    <td class="ps-4">
                      <strong><%= session.creator_name %></strong>
                    </td>
                    <td>
                      <span class="text-secondary">
                        <%= new Date(session.waktu_mulai).toLocaleDateString('id-ID', {day: 'numeric', month: 'short', year: 'numeric'}) %>
                      </span>
                    </td>
                    <td>
                      <span class="text-muted small">
                        <%= new Date(session.waktu_mulai).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) %> - 
                        <%= new Date(session.waktu_selesai).toLocaleTimeString('id-ID', {hour: '2-digit', minute:'2-digit'}) %> WIB
                      </span>
                    </td>
                    <td class="text-end pe-4">
                      <button type="button" class="btn btn-outline-success btn-sm rounded-pill px-3 me-2" onclick="showSummaryModal('<%= session._id %>')">
                        <i class="fa-solid fa-chart-bar me-1"></i> Ringkasan
                      </button>
                      <span class="badge bg-secondary rounded-pill px-3">Selesai</span>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      <% } else { %>
        <div class="text-center py-4 text-secondary">
          <p class="text-muted mb-0 small">Belum ada riwayat sesi Ngaji Bareng sebelumnya.</p>
        </div>
      <% } %>
    </div>

  </div>
</div>

<!-- Countdown script -->
<% if (activeSession) { %>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const timerEl = document.getElementById('session-countdown');
      if (timerEl) {
        const endTimeStr = timerEl.getAttribute('data-endtime');
        const endTime = new Date(endTimeStr).getTime();

        const updateTimer = () => {
          const now = new Date().getTime();
          const distance = endTime - now;

          if (distance < 0) {
            timerEl.innerText = "Sesi Berakhir";
            timerEl.classList.replace('text-success', 'text-danger');
            timerEl.classList.replace('border-success', 'border-danger');
            clearInterval(timerInterval);
            setTimeout(() => {
              window.location.reload();
            }, 2000);
            return;
          }

          const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((distance % (1000 * 60)) / 1000);

          const pad = (num) => String(num).padStart(2, '0');
          timerEl.innerText = `${pad(hours)}:${pad(minutes)}:${pad(seconds)}`;
        };

        updateTimer();
        const timerInterval = setInterval(updateTimer, 1000);
      }
    });
  </script>
<% } %>

<!-- Socket.io real-time feed in Ngaji Bareng Dashboard -->
<script src="/socket.io/socket.io.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof io !== 'undefined') {
      const socket = io();
      
      // Join the Ngaji Bareng socket room
      socket.emit('join_ngaji_bareng');
      
      const feed = document.getElementById('ngajiActivityFeed');
      const placeholder = document.getElementById('noActivityPlaceholder');

      socket.on('ngaji_read_broadcast', (data) => {
        if (!feed) return;
        if (placeholder) {
          placeholder.style.display = 'none';
        }

        const div = document.createElement('div');
        div.className = 'd-flex align-items-center justify-content-between p-2 mb-2 rounded bg-white border border-light animate__animated animate__fadeInLeft shadow-sm';
        
        let roleBadgeColor = 'bg-secondary';
        if (data.role === 'Guru') roleBadgeColor = 'bg-success';
        else if (data.role === 'TU') roleBadgeColor = 'bg-info';
        else if (data.role === 'Admin') roleBadgeColor = 'bg-danger';
        else roleBadgeColor = 'bg-primary';

        div.innerHTML = `
          <div class="d-flex align-items-center gap-2">
            <span class="badge ${roleBadgeColor} rounded-pill text-xs px-2" style="font-size: 0.65rem;">${data.role}</span>
            <strong class="text-primary small">${data.user_name}</strong>
            <span class="text-secondary small">sedang membaca <strong class="text-accent">Surah ${data.surah_name}</strong> Ayat <strong class="text-accent">${data.ayat_number}</strong></span>
          </div>
          <span class="text-muted small" style="font-size: 0.75rem;"><i class="fa-solid fa-clock-rotate-left me-1"></i> Baru saja</span>
        `;

        // Prepend to feed
        feed.insertBefore(div, feed.firstChild);

        // Limit the feed items to 15
        if (feed.children.length > 15) {
          feed.removeChild(feed.lastChild);
        }
      });
    }
  });
</script>

<!-- Modal Detail Ringkasan Ngaji Bareng -->
<div class="modal fade" id="summaryModal" tabindex="-1" aria-labelledby="summaryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(15px);">
      <div class="modal-header border-0 pb-0">
        <h4 class="modal-title font-weight-bold text-primary" id="summaryModalLabel">
          <i class="fa-solid fa-book-quran me-2 text-accent"></i> Ringkasan Sesi Ngaji Bareng
        </h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-3">
        <!-- Loader -->
        <div id="modalLoader" class="text-center py-5">
          <div class="spinner-border text-success mb-2" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
          <p class="text-muted small">Mengambil data ringkasan sesi...</p>
        </div>

        <!-- Content -->
        <div id="modalContent" style="display: none;">
          <!-- Summary Stats -->
          <div class="row g-3 mb-4">
            <div class="col-md-6 col-lg-3">
              <div class="p-3 rounded bg-light border border-light text-center h-100">
                <span class="small text-muted d-block">Dimulai Oleh</span>
                <strong class="text-dark small" id="sumCreator">-</strong>
              </div>
            </div>
            <div class="col-md-6 col-lg-3">
              <div class="p-3 rounded bg-light border border-light text-center h-100">
                <span class="small text-muted d-block">Waktu Mulai</span>
                <strong class="text-dark small" id="sumStart">-</strong>
              </div>
            </div>
            <div class="col-md-6 col-lg-3">
              <div class="p-3 rounded bg-light border border-light text-center h-100">
                <span class="small text-muted d-block">Jumlah Pembaca</span>
                <span class="h4 font-weight-bold text-success d-block my-1" id="sumTotalPembaca">0</span>
                <span class="small text-muted">Orang</span>
              </div>
            </div>
            <div class="col-md-6 col-lg-3">
              <div class="p-3 rounded bg-light border border-light text-center h-100">
                <span class="small text-muted d-block">Total Ayat Dibaca</span>
                <span class="h4 font-weight-bold text-primary d-block my-1" id="sumTotalAyat">0</span>
                <span class="small text-muted">Kali Klik</span>
              </div>
            </div>
          </div>

          <!-- Tabs for Pembaca and Timeline -->
          <ul class="nav nav-tabs nav-fill mb-3" id="summaryTabs" role="tablist">
            <li class="nav-item" role="presentation">
              <button class="nav-link active fw-bold text-success border-0 border-bottom border-3" id="pembaca-tab" data-bs-toggle="tab" data-bs-target="#pembaca-panel" type="button" role="tab" aria-controls="pembaca-panel" aria-selected="true">
                <i class="fa-solid fa-users me-1"></i> Daftar Pembaca
              </button>
            </li>
            <li class="nav-item" role="presentation">
              <button class="nav-link fw-bold text-success border-0 border-bottom border-3" id="timeline-tab" data-bs-toggle="tab" data-bs-target="#timeline-panel" type="button" role="tab" aria-controls="timeline-panel" aria-selected="false">
                <i class="fa-solid fa-timeline me-1"></i> Log Aktivitas
              </button>
            </li>
          </ul>

          <div class="tab-content" id="summaryTabsContent">
            <!-- Panel Pembaca -->
            <div class="tab-pane fade show active" id="pembaca-panel" role="tabpanel" aria-labelledby="pembaca-tab">
              <div class="table-responsive" style="max-height: 350px; overflow-y: auto;">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th style="width: 30%;">Nama & Peran</th>
                      <th style="width: 20%;">Total Ayat</th>
                      <th style="width: 50%;">Surah & Ayat yang Dibaca</th>
                    </tr>
                  </thead>
                  <tbody id="pembacaListTableBody">
                    <!-- Dynamic -->
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Panel Timeline -->
            <div class="tab-pane fade" id="timeline-panel" role="tabpanel" aria-labelledby="timeline-tab">
              <div class="list-group list-group-flush overflow-auto" style="max-height: 350px;" id="timelineListGroup">
                <!-- Dynamic -->
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Tutup</button>
      </div>
    </div>
  </div>
</div>

<script>
  async function showSummaryModal(sessionId) {
    const modalElement = document.getElementById('summaryModal');
    const modal = new bootstrap.Modal(modalElement);
    modal.show();

    const loader = document.getElementById('modalLoader');
    const content = document.getElementById('modalContent');
    
    loader.style.display = 'block';
    content.style.display = 'none';

    try {
      const res = await fetch(`/quran/ngajibareng/summary/${sessionId}`);
      const result = await res.json();
      
      if (!result.success) {
        alert(result.message || 'Gagal mengambil data ringkasan.');
        modal.hide();
        return;
      }

      const data = result.data;

      // Set basic info
      document.getElementById('sumCreator').innerText = data.creator_name;
      document.getElementById('sumStart').innerText = data.waktu_mulai;
      document.getElementById('sumTotalPembaca').innerText = data.total_pembaca;
      document.getElementById('sumTotalAyat').innerText = data.total_ayat_dibaca;

      // Populate Pembaca Table
      const pembacaBody = document.getElementById('pembacaListTableBody');
      pembacaBody.innerHTML = '';
      
      if (data.pembaca && data.pembaca.length > 0) {
        data.pembaca.forEach(p => {
          let roleBadgeColor = 'bg-secondary';
          if (p.role === 'Guru') roleBadgeColor = 'bg-success';
          else if (p.role === 'TU') roleBadgeColor = 'bg-info';
          else if (p.role === 'Admin') roleBadgeColor = 'bg-danger';
          else roleBadgeColor = 'bg-primary';

          let surahDetailHtml = p.surahs.map(s => {
            return `<div class="mb-1"><strong>Surah ${s.surah_name}</strong>: Ayat ${s.ayat_list.join(', ')}</div>`;
          }).join('');

          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>
              <div class="fw-bold text-dark small">${p.user_name}</div>
              <span class="badge ${roleBadgeColor} rounded-pill text-xs px-2" style="font-size: 0.65rem;">${p.role}</span>
            </td>
            <td>
              <span class="badge bg-light text-dark border fw-bold">${p.total_ayat} ayat</span>
            </td>
            <td class="small text-secondary">
              ${surahDetailHtml || '<span class="text-muted italic">Tidak ada detail</span>'}
            </td>
          `;
          pembacaBody.appendChild(tr);
        });
      } else {
        pembacaBody.innerHTML = `<tr><td colspan="3" class="text-center py-4 text-muted small">Tidak ada data pembaca untuk sesi ini.</td></tr>`;
      }

      // Populate Timeline List
      const timelineGroup = document.getElementById('timelineListGroup');
      timelineGroup.innerHTML = '';

      if (data.timeline && data.timeline.length > 0) {
        data.timeline.forEach(t => {
          let roleBadgeColor = 'bg-secondary';
          if (t.role === 'Guru') roleBadgeColor = 'bg-success';
          else if (t.role === 'TU') roleBadgeColor = 'bg-info';
          else if (t.role === 'Admin') roleBadgeColor = 'bg-danger';
          else roleBadgeColor = 'bg-primary';

          const div = document.createElement('div');
          div.className = 'list-group-item d-flex align-items-center justify-content-between py-2 border-0 border-bottom border-light';
          div.innerHTML = `
            <div class="d-flex align-items-center gap-2">
              <span class="badge ${roleBadgeColor} rounded-pill text-xs px-2" style="font-size: 0.65rem;">${t.role}</span>
              <strong class="text-primary small">${t.user_name}</strong>
              <span class="text-secondary small">membaca <strong class="text-accent">Surah ${t.surah_name}</strong> Ayat <strong class="text-accent">${t.ayat_number}</strong></span>
            </div>
            <span class="text-muted small" style="font-size: 0.75rem;"><i class="fa-solid fa-clock me-1"></i> ${t.waktu}</span>
          `;
          timelineGroup.appendChild(div);
        });
      } else {
        timelineGroup.innerHTML = `<div class="text-center py-4 text-muted small">Tidak ada aktivitas membaca yang terekam.</div>`;
      }

      loader.style.display = 'none';
      content.style.display = 'block';

    } catch (error) {
      console.error(error);
      alert('Terjadi kesalahan saat memproses data ringkasan.');
      modal.hide();
    }
  }
</script>

<%- include('../partials/footer') %>
