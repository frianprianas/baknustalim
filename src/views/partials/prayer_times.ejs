<!-- Prayer Times Widget -->
<div class="card-glass p-4 mb-4 position-relative overflow-hidden" id="prayerTimesWidget">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold text-success mb-0">
      <i class="fa-solid fa-clock me-2"></i> Jadwal Sholat
    </h5>
    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill" id="locationName">
      <i class="fa-solid fa-location-dot me-1"></i> Mendeteksi lokasi...
    </span>
  </div>

  <div id="prayerLoading" class="text-center py-4">
    <div class="spinner-border text-success mb-2" role="status" style="width: 2rem; height: 2rem;">
      <span class="visually-hidden">Loading...</span>
    </div>
    <p class="text-secondary small mb-0">Menunggu izin lokasi dari browser Anda...</p>
    <button class="btn btn-sm btn-outline-success mt-2" onclick="requestLocation()">Izinkan Lokasi</button>
  </div>

  <div id="prayerError" class="text-center py-3 d-none">
    <i class="fa-solid fa-triangle-exclamation text-warning fs-3 mb-2"></i>
    <p class="text-secondary small mb-0" id="prayerErrorMessage">Gagal mendapatkan lokasi atau jadwal sholat.</p>
    <button class="btn btn-sm btn-outline-primary mt-2" onclick="requestLocation()">Coba Lagi</button>
  </div>

  <div id="prayerData" class="row g-2 d-none">
    <!-- Items will be injected here via JS -->
  </div>

  <div id="mosquesData" class="mt-4 border-top border-secondary-subtle pt-3 d-none">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <small class="fw-bold text-secondary"><i class="fa-solid fa-mosque me-1"></i> Masjid Terdekat</small>
    </div>
    <div class="row g-2" id="mosquesList">
      <!-- Mosques will be injected here via JS -->
    </div>
    <div id="mosquesLoading" class="text-center py-2 d-none">
      <div class="spinner-border spinner-border-sm text-success" role="status"></div>
    </div>
  </div>
</div>

<script>
  function renderPrayerItem(name, time, isNext) {
    const activeClass = isNext ? 'bg-success text-white' : 'bg-transparent text-secondary';
    const borderClass = isNext ? 'border-success' : 'border-secondary-subtle';
    const textClass = isNext ? 'text-white' : 'text-primary';
    
    return `
      <div class="col-4 col-md-2">
        <div class="p-2 text-center rounded-3 border ${borderClass} ${activeClass}" style="transition: all 0.3s ease;">
          <small class="d-block text-uppercase fw-bold mb-1" style="font-size: 0.7rem; opacity: 0.9;">${name}</small>
          <span class="fw-bold fs-6 ${textClass}">${time}</span>
        </div>
      </div>
    `;
  }

  function fetchPrayerTimes(lat, lng) {
    // method 20 is Ministry of Religious Affairs, Indonesia
    const url = `https://api.aladhan.com/v1/timings?latitude=${lat}&longitude=${lng}&method=20`;
    
    fetch(url)
      .then(res => res.json())
      .then(data => {
        if (data && data.code === 200) {
          const timings = data.data.timings;
          
          // Get location name (reverse geocoding)
          fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=10`)
            .then(res => res.json())
            .then(geo => {
              const city = geo.address.city || geo.address.regency || geo.address.town || 'Lokasi Anda';
              document.getElementById('locationName').innerHTML = `<i class="fa-solid fa-location-dot me-1"></i> ${city}`;
            }).catch(e => {
              document.getElementById('locationName').innerHTML = `<i class="fa-solid fa-location-dot me-1"></i> Lokasi Anda`;
            });

          // Determine next prayer
          const now = new Date();
          const currentTime = now.getHours() * 60 + now.getMinutes();
          
          const prayerList = [
            { name: 'Imsak', key: 'Imsak' },
            { name: 'Subuh', key: 'Fajr' },
            { name: 'Dzuhur', key: 'Dhuhr' },
            { name: 'Ashar', key: 'Asr' },
            { name: 'Maghrib', key: 'Maghrib' },
            { name: 'Isya', key: 'Isha' }
          ];

          let html = '';
          let nextFound = false;

          prayerList.forEach(p => {
            const timeStr = timings[p.key];
            const [h, m] = timeStr.split(':').map(Number);
            const prayerMinutes = h * 60 + m;
            
            let isNext = false;
            if (!nextFound && prayerMinutes > currentTime) {
              isNext = true;
              nextFound = true;
            }

            html += renderPrayerItem(p.name, timeStr, isNext);
          });

          // If no next prayer today, highlight tomorrow's Fajr (first item conceptually)
          // For simplicity, we just won't highlight if nextFound is false.

          document.getElementById('prayerData').innerHTML = html;
          document.getElementById('prayerLoading').classList.add('d-none');
          document.getElementById('prayerError').classList.add('d-none');
          document.getElementById('prayerData').classList.remove('d-none');
          
          // Fetch nearest mosques
          fetchNearestMosques(lat, lng);
          
          // Cache coordinates for 24 hours
          localStorage.setItem('baknus_prayer_loc', JSON.stringify({ lat, lng, timestamp: Date.now() }));
        } else {
          showPrayerError('API tidak merespon dengan baik.');
        }
      })
      .catch(err => {
        showPrayerError('Koneksi internet bermasalah.');
      });
  }

  function showPrayerError(msg) {
    document.getElementById('prayerLoading').classList.add('d-none');
    document.getElementById('prayerData').classList.add('d-none');
    document.getElementById('prayerError').classList.remove('d-none');
    document.getElementById('prayerErrorMessage').innerText = msg;
  }

  function calculateDistance(lat1, lon1, lat2, lon2) {
    const R = 6371; // km
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLon = (lon2 - lon1) * Math.PI / 180;
    const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
              Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
              Math.sin(dLon/2) * Math.sin(dLon/2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    return (R * c * 1000).toFixed(0); // in meters
  }

  function fetchNearestMosques(lat, lng) {
    document.getElementById('mosquesData').classList.remove('d-none');
    document.getElementById('mosquesLoading').classList.remove('d-none');
    
    // Overpass API Query: mosques within 2500m
    const query = `[out:json];nwr(around:2500,${lat},${lng})["amenity"="place_of_worship"]["religion"="muslim"];out center 5;`;
    const url = `https://overpass-api.de/api/interpreter?data=${encodeURIComponent(query)}`;
    
    fetch(url)
      .then(res => res.json())
      .then(data => {
        document.getElementById('mosquesLoading').classList.add('d-none');
        if (data && data.elements && data.elements.length > 0) {
          const mosques = data.elements.map(el => {
            const mLat = el.lat || (el.center && el.center.lat);
            const mLon = el.lon || (el.center && el.center.lon);
            return {
              name: (el.tags && (el.tags.name || el.tags.official_name || el.tags.alt_name || el.tags['name:id'] || el.tags.description)) ? (el.tags.name || el.tags.official_name || el.tags.alt_name || el.tags['name:id'] || el.tags.description) : 'Masjid Terdekat',
              lat: mLat,
              lon: mLon,
              dist: calculateDistance(lat, lng, mLat, mLon)
            };
          }).sort((a, b) => a.dist - b.dist).slice(0, 3);
          
          let html = '';
          mosques.forEach(m => {
            const mapUrl = `https://www.google.com/maps/dir/?api=1&destination=${m.lat},${m.lon}`;
            html += `
              <div class="col-12 col-md-4">
                <a href="${mapUrl}" target="_blank" class="text-decoration-none">
                  <div class="p-2 rounded-3 border border-secondary-subtle bg-transparent text-secondary h-100" style="transition: all 0.2s ease;" onmouseover="this.classList.add('bg-success-subtle', 'border-success', 'text-success'); this.classList.remove('text-secondary', 'border-secondary-subtle');" onmouseout="this.classList.remove('bg-success-subtle', 'border-success', 'text-success'); this.classList.add('text-secondary', 'border-secondary-subtle');">
                    <small class="d-block fw-bold text-primary text-truncate mb-1" style="font-size: 0.8rem;">${m.name}</small>
                    <span class="d-block" style="font-size: 0.7rem;"><i class="fa-solid fa-location-arrow me-1"></i> ${m.dist} meter</span>
                  </div>
                </a>
              </div>
            `;
          });
          document.getElementById('mosquesList').innerHTML = html;
        } else {
          document.getElementById('mosquesList').innerHTML = `<div class="col-12"><small class="text-muted">Tidak ditemukan data masjid terdekat dalam radius 2.5km.</small></div>`;
        }
      })
      .catch(err => {
        document.getElementById('mosquesLoading').classList.add('d-none');
      });
  }

  function requestLocation() {
    document.getElementById('prayerError').classList.add('d-none');
    document.getElementById('prayerLoading').classList.remove('d-none');
    
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          fetchPrayerTimes(position.coords.latitude, position.coords.longitude);
        },
        (error) => {
          let errorMsg = 'Gagal mengambil lokasi.';
          if (error.code === error.PERMISSION_DENIED) errorMsg = 'Akses lokasi ditolak oleh browser. Harap izinkan akses lokasi.';
          showPrayerError(errorMsg);
        },
        { enableHighAccuracy: false, timeout: 10000, maximumAge: 0 }
      );
    } else {
      showPrayerError('Browser Anda tidak mendukung geolokasi.');
    }
  }

  // Initialize
  document.addEventListener('DOMContentLoaded', () => {
    // Check cache
    const cached = localStorage.getItem('baknus_prayer_loc');
    if (cached) {
      try {
        const parsed = JSON.parse(cached);
        // Expire cache after 24 hours
        if (Date.now() - parsed.timestamp < 24 * 60 * 60 * 1000) {
          fetchPrayerTimes(parsed.lat, parsed.lng);
          return;
        }
      } catch(e) {}
    }
    
    // Auto request on load
    requestLocation();
  });
</script>
