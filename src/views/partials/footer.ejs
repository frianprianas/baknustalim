  </div> <!-- Close Container -->

  <footer class="mt-auto py-4 border-top text-center" style="background: var(--bg-secondary) !important; border-top: 1px solid var(--glass-border) !important;">
    <div class="container">
      <p class="text-secondary mb-2">&copy; 2026 <span class="arabic-title-highlight px-2 py-0.5 align-middle" style="font-size: 1.1rem; font-weight: normal;">بَاكْنُوسْ تَعْلِيمْ</span> <span class="small">(BaknusTa'lim)</span> - Bagian dari Ekosistem Digital <a href="https://smk.baktinusantara666.sch.id" target="_blank" class="highlight-school text-decoration-none">SMK Bakti Nusantara 666</a></p>
      <small class="text-muted">Kedaulatan Digital Sekolah, dikembangkan untuk kemandirian penuh.</small>
    </div>
  </footer>

  <!-- Bootstrap 5 Bundle with Popper -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
  
  <!-- Theme Toggle Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const themeToggleBtn = document.getElementById('themeToggleBtn');
      const themeIcon = document.getElementById('themeIcon');
      const themeText = document.getElementById('themeText');
      
      const updateThemeUI = (theme) => {
        if (!themeIcon || !themeText) return;
        if (theme === 'dark') {
          themeIcon.className = 'fa-solid fa-sun me-2 text-warning';
          themeText.innerText = 'Terang';
        } else {
          themeIcon.className = 'fa-solid fa-moon me-2';
          themeText.innerText = 'Gelap';
        }
      };
      
      // Initialize UI based on current theme
      updateThemeUI(document.documentElement.getAttribute('data-bs-theme'));
      
      if (themeToggleBtn) {
        themeToggleBtn.addEventListener('click', () => {
          const currentTheme = document.documentElement.getAttribute('data-bs-theme');
          const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-bs-theme', newTheme);
          localStorage.setItem('theme', newTheme);
          updateThemeUI(newTheme);
        });
      }
    });
  </script>

  <!-- Ngaji Bareng Notification Container -->
  <div id="ngaji-notification-container" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100; max-width: 350px;"></div>

  <% if (typeof currentUser !== 'undefined' && currentUser && typeof activeNgajiSession !== 'undefined' && activeNgajiSession) { %>
    <!-- Socket.IO Ngaji Bareng Global Toast Handler -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        if (typeof io !== 'undefined') {
          const socket = io();
          
          // Join the Ngaji Bareng socket room
          socket.emit('join_ngaji_bareng');
          
          const container = document.getElementById('ngaji-notification-container');
          
          socket.on('ngaji_read_broadcast', (data) => {
            if (!container) return;

            // 1. Cap active popups: limit to maximum of 4 active on screen
            const activeToasts = container.children;
            if (activeToasts.length >= 4) {
              const oldest = activeToasts[0];
              if (oldest && !oldest.classList.contains('animate__fadeOutRight')) {
                oldest.classList.replace('animate__fadeInRight', 'animate__fadeOutRight');
                oldest.addEventListener('animationend', () => oldest.remove());
              }
            }

            // 2. Determine dynamic display duration based on crowd density
            const currentCount = container.children.length;
            let displayDuration = 5000; // Default 5 seconds
            if (currentCount >= 3) {
              displayDuration = 1500; // Dynamic 1.5 seconds if busy
            } else if (currentCount >= 2) {
              displayDuration = 3000; // Dynamic 3 seconds if moderately busy
            }

            // 3. Create a compact, slim toast container
            const toast = document.createElement('div');
            toast.className = 'card-glass p-2 mb-2 animate__animated animate__fadeInRight';
            toast.style.background = 'var(--glass-bg)';
            toast.style.borderColor = 'var(--accent-color)';
            toast.style.borderLeft = '3px solid var(--accent-color)';
            toast.style.boxShadow = '0 6px 20px rgba(0,0,0,0.12)';
            toast.style.backdropFilter = 'blur(12px)';
            toast.style.transition = 'all 0.3s ease';
            
            let roleBadgeColor = 'bg-secondary';
            if (data.role === 'Guru') roleBadgeColor = 'bg-success';
            else if (data.role === 'TU') roleBadgeColor = 'bg-info';
            else if (data.role === 'Admin') roleBadgeColor = 'bg-danger';
            else roleBadgeColor = 'bg-primary';

            // High-density compact HTML layout
            toast.innerHTML = `
              <div class="d-flex align-items-center justify-content-between gap-3 text-nowrap">
                <div class="d-flex align-items-center gap-2 overflow-hidden">
                  <span class="badge ${roleBadgeColor} rounded-pill text-xs px-1.5 py-0.5" style="font-size: 0.6rem; scale: 0.9;">${data.role}</span>
                  <strong class="text-primary small text-truncate" style="max-width: 90px; font-size: 0.8rem;">${data.user_name}</strong>
                  <span class="text-secondary small" style="font-size: 0.78rem;">membaca</span>
                  <strong class="text-accent small" style="font-size: 0.78rem;">QS ${data.surah_name}:${data.ayat_number}</strong>
                </div>
                <i class="fa-solid fa-book-open text-success" style="font-size: 0.8rem; margin-right: 4px;"></i>
              </div>
            `;

            container.appendChild(toast);

            // 4. Set dynamic auto-dismiss
            setTimeout(() => {
              if (toast.parentNode === container) {
                toast.classList.replace('animate__fadeInRight', 'animate__fadeOutRight');
                toast.addEventListener('animationend', () => {
                  toast.remove();
                });
              }
            }, displayDuration);
          });
        }
      });
    </script>
  <% } %>
</body>
</html>
