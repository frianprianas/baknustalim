<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : "BaknusTa'lim" %></title>
  <link rel="icon" type="image/png" href="/img/favicon.png">
  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
  <!-- FontAwesome Icons -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
  <!-- Custom Style -->
  <link rel="stylesheet" href="/css/style.css">
  <!-- Theme Init Script -->
  <script>
    const storedTheme = localStorage.getItem('theme');
    const getPreferredTheme = () => {
      if (storedTheme) {
        return storedTheme;
      }
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };
    document.documentElement.setAttribute('data-bs-theme', getPreferredTheme());
  </script>
</head>
<body>

  <!-- Navigation Bar -->
  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <nav class="navbar navbar-expand-lg navbar-glass">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center text-decoration-none" href="/dashboard">
          <img src="/img/baknus_talim_calligraphy.png" alt="Baknus Ta'lim" style="max-height: 40px; width: auto; margin-right: 8px; filter: drop-shadow(0 2px 6px rgba(21, 128, 61, 0.15));" />
          <span class="ms-1 text-secondary small d-none d-xxl-inline" style="font-weight: 500; font-size: 0.8rem;">(BaknusTa'lim)</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link" href="/dashboard">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-gauge"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Dashboard</span>
                  <span class="nav-caption-sub">Halaman Utama</span>
                </div>
              </a>
            </li>
            
            <!-- Dropdown Al-Qur'an & Hadits -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="quranHaditsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-book-open-reader"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Al-Qur'an & Hadits</span>
                  <span class="nav-caption-sub">Mushaf, Cari & Tanya AI</span>
                </div>
              </a>
              <ul class="dropdown-menu border-0 shadow-sm p-3" aria-labelledby="quranHaditsDropdown" style="background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border) !important; min-width: 240px;">
                <li class="dropdown-header text-success fw-bold px-2 mb-1" style="font-size: 0.85rem;"><i class="fa-solid fa-book-quran me-1"></i> AL-QUR'AN</li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/quran"><i class="fa-solid fa-book-open me-2 text-success" style="width: 16px;"></i> Baca Al-Qur'an</a></li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/quran/murottal"><i class="fa-solid fa-volume-high me-2 text-info" style="width: 16px;"></i> Murottal Audio</a></li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/quran/bookmarks"><i class="fa-solid fa-bookmark me-2 text-warning" style="width: 16px;"></i> Bookmarks Saya</a></li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/quran/ngajibareng"><i class="fa-solid fa-people-group me-2 text-success" style="width: 16px;"></i> Ngaji Bareng</a></li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/belajar"><i class="fa-solid fa-book-open-reader me-2 text-primary" style="width: 16px;"></i> Belajar Islam</a></li>
                
                <li><hr class="dropdown-divider my-2" style="border-color: var(--glass-border);"></li>
                
                <li class="dropdown-header text-success fw-bold px-2 mb-1" style="font-size: 0.85rem;"><i class="fa-solid fa-book-journal-whills me-1"></i> AL-HADITS</li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/hadits"><i class="fa-solid fa-magnifying-glass me-2 text-primary" style="width: 16px;"></i> Cari Hadits</a></li>
                <li><a class="dropdown-item rounded py-2 ps-3" href="/hadits/tanya"><i class="fa-solid fa-robot me-2 text-success" style="width: 16px;"></i> Tanya Hadits AI</a></li>
              </ul>
            </li>
            
            <li class="nav-item">
              <a class="nav-link" href="/belajar">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-book-open-reader text-primary"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Belajar Islam</span>
                  <span class="nav-caption-sub">Tajwid, Fiqih, Akhlak</span>
                </div>
              </a>
            </li>
            
            <li class="nav-item">
              <a class="nav-link" href="/tanya">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-comments"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Tanya Yuk!</span>
                  <span class="nav-caption-sub">Diskusi Agama</span>
                </div>
              </a>
            </li>
            
            <li class="nav-item">
              <a class="nav-link" href="/live">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-tower-broadcast"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Kajian Live</span>
                  <span class="nav-caption-sub">Streaming & Tanya</span>
                </div>
              </a>
            </li>
            
            <!-- PAI Teacher or Admin Actions -->
            <% if (currentUser.role === 'admin' || (currentUser.role === 'guru' && currentUser.is_guru_pai)) { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="evalDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <div class="nav-icon-wrapper">
                    <i class="fa-solid fa-file-signature"></i>
                  </div>
                  <div class="nav-text-container">
                    <span class="nav-label-main">Penilaian</span>
                    <span class="nav-caption-sub">Evaluasi Siswa</span>
                  </div>
                </a>
                <ul class="dropdown-menu border-0 shadow-sm p-2" aria-labelledby="evalDropdown" style="background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border) !important;">
                  <li><a class="dropdown-item rounded py-2" href="/hafalan/input"><i class="fa-solid fa-microphone me-2 text-info"></i> Input Hafalan</a></li>
                  <li><a class="dropdown-item rounded py-2" href="/ibadah/input"><i class="fa-solid fa-hands-praying me-2 text-success"></i> Input Praktek Ibadah</a></li>
                </ul>
              </li>
            <% } %>
 
            <!-- Admin Controls -->
            <% if (currentUser.role === 'admin') { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <div class="nav-icon-wrapper">
                    <i class="fa-solid fa-user-shield text-accent"></i>
                  </div>
                  <div class="nav-text-container">
                    <span class="nav-label-main">Admin Panel</span>
                    <span class="nav-caption-sub">Kelola Sistem</span>
                  </div>
                </a>
                <ul class="dropdown-menu border-0 shadow-sm p-2" aria-labelledby="adminDropdown" style="background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border) !important;">
                  <li><a class="dropdown-item rounded py-2" href="/admin/users"><i class="fa-solid fa-users me-2 text-primary"></i> Kelola User</a></li>
                  <li><a class="dropdown-item rounded py-2" href="/admin/kelas"><i class="fa-solid fa-school me-2 text-success"></i> Kelola Kelas</a></li>
                  <li><a class="dropdown-item rounded py-2" href="/admin/ibadah"><i class="fa-solid fa-list-check me-2 text-warning"></i> Kelola Jenis Ibadah</a></li>
                </ul>
              </li>
            <% } %>
 
            <!-- Dropdown Amalan Yaumi -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="amalanDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-square-check text-success"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Amalan Yaumi</span>
                  <span class="nav-caption-sub">Checklist & Laporan</span>
                </div>
              </a>
              <ul class="dropdown-menu border-0 shadow-sm p-2" aria-labelledby="amalanDropdown" style="background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border) !important;">
                <% if (currentUser.role === 'siswa') { %>
                  <li><a class="dropdown-item rounded py-2" href="/amalan"><i class="fa-solid fa-calendar-check me-2 text-success"></i> Isi Checklist Harian</a></li>
                  <li><a class="dropdown-item rounded py-2" href="/amalan/riwayat"><i class="fa-solid fa-clock-rotate-left me-2 text-info"></i> Riwayat Amalan Saya</a></li>
                <% } %>
                <% if (currentUser.role === 'admin' || (currentUser.role === 'guru' && currentUser.is_guru_pai) || currentUser.role === 'tu') { %>
                  <li><a class="dropdown-item rounded py-2" href="/amalan/laporan"><i class="fa-solid fa-chart-line me-2 text-primary"></i> Laporan Amalan Siswa</a></li>
                <% } %>
              </ul>
            </li>

            <!-- History log lookup (open to all) -->
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="historyDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <div class="nav-icon-wrapper">
                  <i class="fa-solid fa-history"></i>
                </div>
                <div class="nav-text-container">
                  <span class="nav-label-main">Riwayat</span>
                  <span class="nav-caption-sub">Log Aktivitas</span>
                </div>
              </a>
              <ul class="dropdown-menu border-0 shadow-sm p-2" aria-labelledby="historyDropdown" style="background: var(--glass-bg); backdrop-filter: blur(12px); border: 1px solid var(--glass-border) !important;">
                <li><a class="dropdown-item rounded py-2" href="/hafalan/riwayat"><i class="fa-solid fa-book-open me-2 text-info"></i> Hafalan Qur'an</a></li>
                <li><a class="dropdown-item rounded py-2" href="/ibadah/riwayat"><i class="fa-solid fa-person-praying me-2 text-success"></i> Praktek Ibadah</a></li>
              </ul>
            </li>
          </ul>

          <div class="d-flex align-items-center gap-2">
            <!-- Theme Toggle -->
            <button class="btn btn-sm btn-outline-secondary rounded-pill d-flex align-items-center justify-content-center px-3 me-1" id="themeToggleBtn" style="border-color: var(--glass-border); color: var(--text-primary);" title="Ganti Tema Terang/Gelap">
              <i class="fa-solid fa-moon me-2" id="themeIcon"></i> <span id="themeText" class="fw-medium" style="font-size: 0.8rem;">Gelap</span>
            </button>
            
            <div class="d-flex align-items-center justify-content-center rounded-circle border border-success text-white fw-bold d-none d-lg-inline-flex" style="width: 32px; height: 32px; background-color: #15803d; overflow: hidden; font-size: 0.9rem; flex-shrink: 0;">
              <img src="https://baknusmail.smkbn666.sch.id/api/public/avatar/<%= currentUser.mailcow_email %>"
                   alt="Avatar"
                   style="width: 100%; height: 100%; object-fit: cover;"
                   onerror="this.style.display='none'; this.parentElement.innerText='<%= (currentUser.nama || 'B').charAt(0).toUpperCase() %>';" />
            </div>
            <span class="text-primary me-2 d-none d-xxl-inline">
              <small class="text-secondary">Login sebagai:</small> 
              <strong><%= currentUser.nama || (currentUser.profile && currentUser.profile.displayName) %></strong> 
              <span class="badge rounded-pill text-uppercase" style="background-color: var(--bg-tertiary) !important; color: var(--accent-color) !important; border: 1px solid var(--glass-border) !important; font-size: 0.7rem;"><%= currentUser.role === 'guru' && currentUser.is_guru_pai ? 'Guru PAI' : currentUser.role %></span>
            </span>
            <a href="/auth/logout" class="btn btn-outline-danger btn-sm rounded-pill px-3">
              <i class="fa-solid fa-right-from-bracket me-1"></i> Keluar
            </a>
          </div>
        </div>
      </div>
    </nav>
  <% } %>

  <div class="container my-4 flex-grow-1">
    
    <!-- Success/Error alert systems -->
    <% if (typeof successMessage !== 'undefined' && successMessage) { %>
      <div class="alert alert-success alert-dismissible fade show border-0 card-glass position-relative shadow" role="alert" style="background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3) !important;">
        <i class="fa-solid fa-circle-check me-2"></i> <%= successMessage %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="alert alert-danger alert-dismissible fade show border-0 card-glass position-relative shadow" role="alert" style="background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3) !important;">
        <i class="fa-solid fa-circle-exclamation me-2"></i> <%= errorMessage %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% } %>
