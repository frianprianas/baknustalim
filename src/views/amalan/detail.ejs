<%- include('../partials/header') %>

<div class="row justify-content-center animate__animated animate__fadeIn">
  <div class="col-lg-10 col-md-12">

    <div class="d-flex align-items-center mb-4 d-print-none">
      <a href="/amalan/laporan" class="btn btn-outline-light rounded-circle me-3" style="width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <h1 class="h2 mb-1"><i class="fa-solid fa-square-check me-2 text-success"></i> Detail Amalan: <%= student.nama %></h1>
        <p class="text-secondary mb-0">Tinjau log aktivitas ibadah fardhu & sunnah harian secara detail.</p>
      </div>
    </div>

    <!-- Student details card -->
    <div class="card-glass p-4 mb-4">
      <div class="row align-items-center">
        <div class="col-auto">
          <div class="d-flex align-items-center justify-content-center rounded-circle border border-success shadow-sm text-white fw-bold fs-2" style="width: 60px; height: 60px; background-color: #15803d; overflow: hidden; flex-shrink: 0;">
            <img src="https://baknusmail.smkbn666.sch.id/api/auth/avatar/<%= student.mailcow_email %>"
                 alt="Avatar"
                 style="width: 100%; height: 100%; object-fit: cover;"
                 onerror="this.style.display='none'; this.parentElement.innerText='<%= (student.nama || 'B').charAt(0).toUpperCase() %>';" />
          </div>
        </div>
        <div class="col">
          <h4 class="mb-1"><%= student.nama %></h4>
          <p class="text-secondary mb-0">
            <strong>NIS:</strong> <%= student.nis || '-' %> &bull; 
            <strong>Kelas:</strong> <%= student.kelas_id ? student.kelas_id.nama_kelas : 'Belum Ada Kelas' %> &bull; 
            <strong>Email:</strong> <%= student.mailcow_email %>
          </p>
        </div>
        <div class="col-md-auto mt-3 mt-md-0 d-print-none">
          <button onclick="window.print()" class="btn btn-outline-info rounded-pill">
            <i class="fa-solid fa-print me-1"></i> Cetak Detail Siswa
          </button>
        </div>
      </div>
    </div>

    <!-- Print Header (Visible ONLY on Print) -->
    <div class="d-none d-print-block mb-5 text-dark">
      <div class="text-center border-bottom pb-3 mb-4">
        <h3 class="mb-1"><strong>SMK BAKTI NUSANTARA 666</strong></h3>
        <p class="mb-1 text-muted">LAPORAN DETAIL AMALAN YAUMI SISWA</p>
        <small>Nama Siswa: <%= student.nama %> | Kelas: <%= student.kelas_id ? student.kelas_id.nama_kelas : '-' %></small>
      </div>
    </div>

    <!-- History Table -->
    <div class="card-glass p-4">
      <% if (history && history.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-custom align-middle">
            <thead>
              <tr>
                <th>Tanggal</th>
                <th class="text-center">Salat Fardhu (Wajib)</th>
                <th class="text-center">Salat Sunnah</th>
                <th class="text-center">Puasa Sunnah</th>
              </tr>
            </thead>
            <tbody>
              <% history.forEach(log => { %>
                <tr>
                  <td>
                    <strong><%= new Date(log.tanggal).toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></strong>
                  </td>
                  
                  <!-- Salat Fardhu -->
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-1 flex-wrap">
                      <% const fardus = [
                        { key: 'subuh', label: 'S' },
                        { key: 'dzuhur', label: 'D' },
                        { key: 'ashar', label: 'A' },
                        { key: 'maghrib', label: 'M' },
                        { key: 'isya', label: 'I' }
                      ] %>
                      <% fardus.forEach(f => { %>
                        <% const done = log.sholat_fardu && log.sholat_fardu[f.key] %>
                        <span class="badge rounded-circle d-inline-flex align-items-center justify-content-center" 
                              style="width: 25px; height: 25px; font-size: 0.72rem; 
                                     background-color: <%= done ? 'rgba(22, 163, 74, 0.15)' : 'rgba(239, 68, 68, 0.08)' %>; 
                                     color: <%= done ? '#16a34a' : '#ef4444' %>;
                                     border: 1px solid <%= done ? 'rgba(22, 163, 74, 0.3)' : 'rgba(239, 68, 68, 0.2)' %>;" 
                              title="<%= f.key.toUpperCase() %>: <%= done ? 'Telah Dikerjakan' : 'Belum/Tidak' %>">
                          <%= f.label %>
                        </span>
                      <% }) %>
                    </div>
                  </td>

                  <!-- Salat Sunnah -->
                  <td class="text-center">
                    <% let sunnahList = [] %>
                    <% if (log.sholat_sunnah && log.sholat_sunnah.tahajud) sunnahList.push('Tahajud') %>
                    <% if (log.sholat_sunnah && log.sholat_sunnah.duha) sunnahList.push('Duha') %>
                    <% if (log.sholat_sunnah && log.sholat_sunnah.rawatib) sunnahList.push('Rawatib') %>
                    
                    <% if (sunnahList.length > 0) { %>
                      <div class="d-flex justify-content-center gap-1 flex-wrap">
                        <% sunnahList.forEach(s => { %>
                          <span class="badge bg-info-subtle text-info border border-info-subtle py-1 px-2 rounded-pill" style="font-size: 0.7rem;">
                            <%= s %>
                          </span>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <span class="text-muted small">-</span>
                    <% } %>
                  </td>

                  <!-- Puasa -->
                  <td class="text-center">
                    <% let puasaList = [] %>
                    <% if (log.puasa && log.puasa.senin) puasaList.push('Senin') %>
                    <% if (log.puasa && log.puasa.kamis) puasaList.push('Kamis') %>
                    <% if (log.puasa && log.puasa.ayyamul_bidh) puasaList.push('Ayyamul Bidh') %>
                    
                    <% if (puasaList.length > 0) { %>
                      <div class="d-flex justify-content-center gap-1 flex-wrap">
                        <% puasaList.forEach(p => { %>
                          <span class="badge bg-warning-subtle text-warning border border-warning-subtle py-1 px-2 rounded-pill" style="font-size: 0.7rem;">
                            <%= p %>
                          </span>
                        <% }) %>
                      </div>
                    <% } else { %>
                      <span class="text-muted small">-</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="text-center py-5 text-secondary">
          <i class="fa-solid fa-folder-open fa-3x mb-3 text-muted"></i>
          <p class="mb-0">Belum ada riwayat amalan tercatat untuk siswa ini.</p>
        </div>
      <% } %>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
