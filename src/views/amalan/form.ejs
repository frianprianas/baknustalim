<%- include('../partials/header') %>

<div class="row justify-content-center animate__animated animate__fadeIn">
  <div class="col-lg-8 col-md-10">

    <div class="d-flex align-items-center mb-4">
      <a href="/dashboard" class="btn btn-outline-light rounded-circle me-3" style="width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <h1 class="h2 mb-1"><i class="fa-solid fa-calendar-check me-2 text-success"></i> Amalan Yaumi Siswa</h1>
        <p class="text-secondary mb-0">Catat dan evaluasi amalan ibadah harian Anda secara mandiri.</p>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger border-0 small text-center mb-4 py-2" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2) !important;">
        <i class="fa-solid fa-triangle-exclamation me-1"></i> <%= error %>
      </div>
    <% } %>

    <!-- Date Selection Form -->
    <div class="card-glass p-3 mb-4 d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div class="d-flex align-items-center gap-2">
        <i class="fa-solid fa-calendar text-success fs-5"></i>
        <span class="fw-semibold">Tanggal Amalan:</span>
      </div>
      <div>
        <form action="/amalan" method="GET" class="d-flex gap-2">
          <input type="date" class="form-control border-secondary form-control-sm" name="tanggal" value="<%= selectedDateStr %>" max="<%= new Date().toISOString().split('T')[0] %>" onchange="this.form.submit()">
        </form>
      </div>
    </div>

    <div class="card-glass p-4 p-md-5">
      <form action="/amalan" method="POST">
        <input type="hidden" name="tanggal" value="<%= selectedDateStr %>">
        
        <!-- Halangan Toggle (Haid) -->
        <div class="card-glass p-3 mb-4 border border-info" style="background: rgba(6, 182, 212, 0.05); border-radius: 12px;">
          <div class="form-check form-switch d-flex align-items-center justify-content-between p-0">
            <label class="form-check-label fw-bold text-info mb-0 d-flex align-items-center gap-2" for="is_halangan" style="cursor: pointer;">
              <i class="fa-solid fa-venus fs-5"></i>
              <div>
                <span>Sedang Halangan / Haid</span>
                <small class="text-secondary d-block font-weight-normal" style="font-size: 0.75rem;">(Khusus Siswi - Wajib salat & puasa dinonaktifkan dan tidak mengurangi nilai kepatuhan)</small>
              </div>
            </label>
            <div class="form-check form-switch">
              <input class="form-check-input fs-4" type="checkbox" role="switch" name="is_halangan" id="is_halangan" <%= log.is_halangan ? 'checked' : '' %>>
            </div>
          </div>
        </div>
        
        <!-- Sholat Fardhu Checklist -->
        <div class="mb-5">
          <h5 class="fw-bold mb-3 border-bottom pb-2 text-success">
            <i class="fa-solid fa-mosque me-2"></i> Salat Fardhu
          </h5>
          <p class="text-secondary small mb-3">Pilih salat wajib yang Anda tunaikan tepat waktu hari ini:</p>
          <div class="row row-cols-2 row-cols-sm-5 g-2">
            <% const fardus = [
              { key: 'subuh', label: 'Subuh', icon: 'fa-cloud-sun' },
              { key: 'dzuhur', label: 'Dzuhur', icon: 'fa-sun' },
              { key: 'ashar', label: 'Ashar', icon: 'fa-cloud-sun-rain' },
              { key: 'maghrib', label: 'Maghrib', icon: 'fa-moon' },
              { key: 'isya', label: 'Isya', icon: 'fa-star-and-crescent' }
            ] %>
            <% fardus.forEach(f => { %>
              <div class="col">
                <input type="checkbox" class="btn-check" name="fardu[<%= f.key %>]" id="fardu_<%= f.key %>" <%= log.sholat_fardu && log.sholat_fardu[f.key] ? 'checked' : '' %> autocomplete="off">
                <label class="btn btn-outline-success w-100 py-3 d-flex flex-column align-items-center justify-content-center border-secondary rounded-3" for="fardu_<%= f.key %>">
                  <i class="fa-solid <%= f.icon %> mb-2 fs-4"></i>
                  <span><%= f.label %></span>
                </label>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Sholat Sunnah Checklist -->
        <div class="mb-5">
          <h5 class="fw-bold mb-3 border-bottom pb-2 text-info">
            <i class="fa-solid fa-moon me-2"></i> Salat Sunnah
          </h5>
          <p class="text-secondary small mb-3">Pilih salat sunnah yang Anda dirikan:</p>
          <div class="row row-cols-1 row-cols-sm-3 g-3">
            <% const sunnahs = [
              { key: 'tahajud', label: 'Tahajud (Qiyamul Lail)', desc: 'Dikerjakan di sepertiga malam' },
              { key: 'duha', label: 'Duha', desc: 'Dikerjakan pagi hingga menjelang dzuhur' },
              { key: 'rawatib', label: 'Rawatib (Qobliyah/Ba\'diyah)', desc: 'Salat pengiring salat fardhu' }
            ] %>
            <% sunnahs.forEach(s => { %>
              <div class="col">
                <input type="checkbox" class="btn-check" name="sunnah[<%= s.key %>]" id="sunnah_<%= s.key %>" <%= log.sholat_sunnah && log.sholat_sunnah[s.key] ? 'checked' : '' %> autocomplete="off">
                <label class="btn btn-outline-info w-100 p-3 text-start border-secondary rounded-3 d-flex align-items-start gap-3" for="sunnah_<%= s.key %>">
                  <i class="fa-regular fa-square-check fs-4 mt-1"></i>
                  <div>
                    <span class="d-block fw-bold"><%= s.label %></span>
                    <small class="text-secondary" style="font-size:0.75rem;"><%= s.desc %></small>
                  </div>
                </label>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Puasa Sunnah Checklist -->
        <div class="mb-5">
          <h5 class="fw-bold mb-3 border-bottom pb-2 text-warning">
            <i class="fa-solid fa-droplet-slash me-2"></i> Puasa Sunnah
          </h5>
          <p class="text-secondary small mb-3">Pilih puasa sunnah yang Anda laksanakan hari ini (jika sedang berpuasa):</p>
          <div class="row row-cols-1 row-cols-sm-3 g-3">
            <% const puasaList = [
              { key: 'senin', label: 'Puasa Senin', desc: 'Puasa sunnah hari senin' },
              { key: 'kamis', label: 'Puasa Kamis', desc: 'Puasa sunnah hari kamis' },
              { key: 'ayyamul_bidh', label: 'Ayyamul Bidh', desc: 'Puasa tanggal 13, 14, 15 Hijriyah' }
            ] %>
            <% puasaList.forEach(p => { %>
              <div class="col">
                <input type="checkbox" class="btn-check" name="puasa[<%= p.key %>]" id="puasa_<%= p.key %>" <%= log.puasa && log.puasa[p.key] ? 'checked' : '' %> autocomplete="off">
                <label class="btn btn-outline-warning w-100 p-3 text-start border-secondary rounded-3 d-flex align-items-start gap-3" for="puasa_<%= p.key %>">
                  <i class="fa-regular fa-square-check fs-4 mt-1"></i>
                  <div>
                    <span class="d-block fw-bold"><%= p.label %></span>
                    <small class="text-secondary" style="font-size:0.75rem;"><%= p.desc %></small>
                  </div>
                </label>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Submit actions -->
        <div class="d-flex justify-content-end gap-3 pt-3 border-top border-secondary">
          <a href="/dashboard" class="btn btn-secondary-custom">Batal</a>
          <button type="submit" class="btn btn-primary-custom">
            <i class="fa-solid fa-save me-1"></i> Simpan Amalan
          </button>
        </div>

      </form>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const isHalanganCheckbox = document.getElementById('is_halangan');
    const checklistInputs = document.querySelectorAll('input.btn-check');

    function toggleInputs() {
      const isChecked = isHalanganCheckbox.checked;
      checklistInputs.forEach(input => {
        input.disabled = isChecked;
        if (isChecked) {
          input.checked = false;
        }
      });
    }

    isHalanganCheckbox.addEventListener('change', toggleInputs);
    // Initial evaluation
    toggleInputs();
  });
</script>

<%- include('../partials/footer') %>
