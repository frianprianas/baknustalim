<%- include('../partials/header') %>

<div class="row mb-4 align-items-center d-print-none animate__animated animate__fadeIn">
  <div class="col-12">
    <div class="card-glass p-3 p-sm-4 mb-4" style="background: linear-gradient(135deg, rgba(22, 163, 74, 0.08) 0%, rgba(22, 163, 74, 0.16) 100%);">
      <div class="row align-items-center">
        <div class="col-auto">
          <div class="bg-success text-white p-3 rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 55px; height: 55px;">
            <i class="fa-solid fa-square-check fs-4"></i>
          </div>
        </div>
        <div class="col">
          <span class="text-secondary text-uppercase small tracking-wider font-weight-bold">Monitoring Kepatuhan</span>
          <h1 class="h3 mb-0">Laporan Amalan Yaumi Siswa</h1>
          <p class="text-secondary mb-0">Tinjau rekapitulasi kepatuhan ibadah wajib dan sunnah siswa di kelas.</p>
        </div>
        <div class="col-md-auto mt-3 mt-md-0">
          <button onclick="window.print()" class="btn btn-outline-info rounded-pill px-3">
            <i class="fa-solid fa-print me-1"></i> Cetak PDF Laporan
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Report Filter Card (Hidden on Print) -->
<div class="card-glass p-4 mb-4 d-print-none">
  <h5 class="mb-3 text-secondary"><i class="fa-solid fa-filter me-2"></i> Filter Laporan</h5>
  <form action="/amalan/laporan" method="GET" class="row g-3">
    <div class="col-md-5">
      <label for="class_id" class="form-label">Pilih Kelas</label>
      <select class="form-select" id="class_id" name="class_id" onchange="this.form.submit()">
        <option value="">-- Semua Kelas --</option>
        <% classes.forEach(c => { %>
          <option value="<%= c._id %>" <%= selectedClass === c._id.toString() ? 'selected' : '' %>>
            <%= c.nama_kelas %> (<%= c.tahun_ajaran %>)
          </option>
        <% }) %>
      </select>
    </div>
    
    <div class="col-md-5">
      <label for="search" class="form-label">Cari Nama / NIS Siswa</label>
      <input type="text" class="form-control" id="search" name="search" placeholder="Masukkan nama atau NIS..." value="<%= searchQuery %>">
    </div>

    <div class="col-md-2 d-flex align-items-end">
      <button type="submit" class="btn btn-primary-custom w-100 py-2">
        <i class="fa-solid fa-magnifying-glass me-1"></i> Filter
      </button>
    </div>
  </form>
</div>

<!-- Print Header (Visible ONLY on Print) -->
<div class="d-none d-print-block mb-5 text-dark">
  <div class="text-center border-bottom pb-3 mb-4">
    <h3 class="mb-1"><strong>SMK BAKTI NUSANTARA 666</strong></h3>
    <p class="mb-1 text-muted">LAPORAN REKAPITULASI AMALAN YAUMI SISWA</p>
    <small>Tanggal Cetak: <%= new Date().toLocaleDateString('id-ID', {day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute:'2-digit'}) %></small>
  </div>
</div>

<%
  let totalSiswa = reportData.length;
  let totalFardhuDone = 0;
  let totalFardhuExpected = 0;
  let totalSunnah = 0;
  let totalPuasa = 0;
  reportData.forEach(r => {
    totalFardhuDone += r.fardu.done;
    totalFardhuExpected += r.fardu.expected;
    totalSunnah += r.sunnah;
    totalPuasa += r.puasa;
  });
  let avgFardhuPct = totalFardhuExpected > 0 ? Math.round((totalFardhuDone / totalFardhuExpected) * 100) : 0;
%>

<!-- Stats Summary Grid for PAI Teachers (Hidden on Print) -->
<div class="row mb-4 d-print-none animate__animated animate__fadeIn">
  <div class="col-md-3 mb-3">
    <div class="card-glass p-3 h-100 border-start border-4 border-success">
      <span class="text-secondary small d-block mb-1">Total Siswa</span>
      <h3 class="mb-0 fw-bold text-success"><%= totalSiswa %> <span class="fs-6 text-muted font-weight-normal">Siswa</span></h3>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card-glass p-3 h-100 border-start border-4 border-info">
      <span class="text-secondary small d-block mb-1">Kepatuhan Fardhu</span>
      <h3 class="mb-0 fw-bold text-info"><%= avgFardhuPct %>%</h3>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card-glass p-3 h-100 border-start border-4 border-primary">
      <span class="text-secondary small d-block mb-1">Total Salat Sunnah</span>
      <h3 class="mb-0 fw-bold text-primary"><%= totalSunnah %> <span class="fs-6 text-muted font-weight-normal">Kali</span></h3>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="card-glass p-3 h-100 border-start border-4 border-warning">
      <span class="text-secondary small d-block mb-1">Total Puasa Sunnah</span>
      <h3 class="mb-0 fw-bold text-warning"><%= totalPuasa %> <span class="fs-6 text-muted font-weight-normal">Hari</span></h3>
    </div>
  </div>
</div>

<!-- Recap Table Card -->
<div class="card-glass p-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="mb-0"><i class="fa-solid fa-table-list me-2 text-accent"></i> Hasil Rekapitulasi Amalan</h5>
    <span class="badge" style="background-color: var(--bg-tertiary) !important; color: var(--accent-color) !important; border: 1px solid var(--glass-border) !important; font-size: 0.85rem;"><%= reportData.length %> Siswa Ditemukan</span>
  </div>

  <% if (reportData && reportData.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-custom align-middle">
        <thead>
          <tr>
            <th>NIS</th>
            <th>Nama Siswa</th>
            <th>Kelas</th>
            <th class="text-center">Hari Mengisi</th>
            <th class="text-center">Kepatuhan Fardhu</th>
            <th class="text-center">Salat Sunnah (Kali)</th>
            <th class="text-center">Puasa Sunnah (Hari)</th>
            <th class="text-end d-print-none">Detail</th>
          </tr>
        </thead>
        <tbody>
          <% reportData.forEach(row => { %>
            <tr>
              <td><strong><%= row.nis %></strong></td>
              <td>
                <a href="/amalan/detail/<%= row.id %>" class="fw-bold text-success text-decoration-none" style="transition: color 0.2s;" onmouseover="this.style.color='var(--accent-color-hover)'" onmouseout="this.style.color='text-success'">
                  <%= row.nama %>
                </a>
              </td>
              <td><span class="badge bg-light text-dark border"><%= row.kelas %></span></td>
              <td class="text-center fw-bold text-success"><%= row.daysFilled %> hari</td>
              
              <!-- Salat Fardhu Compliance -->
              <td class="text-center">
                <% const percentage = row.daysFilled === 0 ? 0 : (row.fardu.expected > 0 ? Math.round((row.fardu.done / row.fardu.expected) * 100) : 100) %>
                <span class="fw-bold <%= percentage >= 80 ? 'text-success' : percentage >= 50 ? 'text-warning' : 'text-danger' %>">
                  <%= row.fardu.done %>
                </span>
                <span class="text-secondary small">/ <%= row.fardu.expected %> (<%= percentage %>%)</span>
                <div class="progress mt-1 mx-auto d-print-none" style="height: 4px; max-width: 100px; background-color: var(--bg-tertiary);">
                  <div class="progress-bar bg-success" role="progressbar" style="width: <%= percentage %>%"></div>
                </div>
              </td>
              
              <!-- Salat Sunnah Count -->
              <td class="text-center text-info fw-bold">
                <%= row.sunnah %>
              </td>

              <!-- Puasa Count -->
              <td class="text-center text-warning fw-bold">
                <%= row.puasa %>
              </td>

              <!-- Detail Action Link -->
              <td class="text-end d-print-none">
                <a href="/amalan/detail/<%= row.id %>" class="btn btn-outline-secondary btn-sm rounded" title="Lihat Detail Riwayat">
                  <i class="fa-solid fa-eye me-1"></i> Detail
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="text-center py-5 text-secondary">
      <i class="fa-solid fa-folder-open fa-3x mb-3 text-muted"></i>
      <p class="mb-0">Tidak ada data siswa ditemukan.</p>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
