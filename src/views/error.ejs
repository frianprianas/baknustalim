<%- include('partials/header') %>

<div class="row justify-content-center my-5">
  <div class="col-md-8 col-lg-6">
    <div class="card-glass text-center p-5 border-danger">
      <div class="text-danger mb-4">
        <i class="fa-solid fa-circle-xmark fa-4x animate__animated animate__pulse animate__infinite"></i>
      </div>
      <h1 class="h3 mb-3 text-danger"><%= title %></h1>
      <p class="text-secondary mb-4"><%= message %></p>
      
      <% if (typeof error !== 'undefined' && error && error.stack && process.env.NODE_ENV !== 'production') { %>
        <div class="text-start p-3 rounded mb-4 overflow-auto" style="max-height: 200px; font-family: monospace; font-size: 0.8rem; background-color: var(--bg-tertiary) !important; border: 1px solid var(--glass-border) !important;">
          <pre class="text-danger m-0"><%= error.stack %></pre>
        </div>
      <% } %>

      <div class="d-flex justify-content-center gap-3">
        <button onclick="window.history.back()" class="btn btn-secondary-custom">
          <i class="fa-solid fa-arrow-left me-1"></i> Kembali
        </button>
        <a href="/dashboard" class="btn btn-primary-custom">
          <i class="fa-solid fa-house me-1"></i> Ke Dashboard
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
